<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monthly Patient Report</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <!-- Custom CSS for reducing font size and making the layout PDF-friendly -->
    <style>
        body {
            font-size: 12px;
            line-height: 1.5;
        }
        
        .table th,
        .table td {
            font-size: 10px;
        }

        .fw-bold {
            font-weight: bold;
        }

        .page-break {
            page-break-after: always;
        }
    </style>
</head>

<body>
    <% for (const doctorId in doctors) { 
        const doctor = doctors[doctorId]; %>
        <div class="text-center text-capitalize mt-3">
            <!-- Doctor's Name -->
            <h3>Dr.&nbsp;<%= doctor.DoctorFirstName %> <%= doctor.DoctorLastName %></h3>
            
            <!-- Degrees -->
            <h6 class="mb-1"><%= doctor.Degree1 %>&nbsp;<%= doctor.Degree2 %>&nbsp;<%= doctor.Degree3 %></h6>
            <h6 class="mb-1"><%= doctor.Degree4 %> &nbsp;<%= doctor.SpecialistIn %></h6>
        
            <!-- Work Information -->
            <h6 class="mb-0"><%= doctor.SpecialistIn %></h6>
        </div>
        <hr>
        
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>#</th>
                    <th>P Name</th>
                    <th>Test</th>
                    <th>Date</th>
                    <th>Gross Fee</th>
                    <th>Disc</th>
                    <th>Dues</th>
                    <th>Thanks</th>
                </tr>
            </thead>
            <tbody>
                <% let i = 1; doctor.patients.forEach(patient => { %>
                    <tr>
                        <td><%= i %>.</td>
                        <td>
                            <%= patient.PatientName %> <br>
                            <small><%= patient.Age %>&nbsp;<%= patient.YMD %></small> <br> 
                            <small><%= patient.Gender %></small>
                        </td>
                        <td>
                            <%= patient.Tests %> <br>
                            <small><%= patient.Subtest %></small>
                        </td>
                        <td>
                            <%= new Date(patient.RegisteredOn).toLocaleDateString() %>
                        </td>
                        <td>
                            <%= patient.GrossAmount %>
                        </td>
                        <td>
                            <%= patient.Discount %>
                        </td>
                        <td>
                            <%= patient.DuesAmount %>
                        </td>
                        <td>
                            <%= patient.Thanks %>
                        </td>
                    </tr>
                    <% i++; %>
                <% }) %>
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3"></td>
                    <td class="fw-bold">Total</td>
                    <td class="fw-bold"><%= doctor.TotalGrossFee.toLocaleString() %></td>
                    <td class="fw-bold"><%= doctor.TotalDiscount.toLocaleString() %></td>
                    <td class="fw-bold"><%= doctor.TotalDues.toLocaleString() %></td>
                    <td class="fw-bold"><%= doctor.TotalThanks.toLocaleString() %></td>
                </tr>
            </tfoot>
        </table>
        <div class="page-break"></div>
    <% } %>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Monthly Patient Report</title>

  <!-- Bootstrap 5.3 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <style>
    body {
      font-size: 12px;
      background-color: #fff;
    }

    .report-container {
      padding: 24px;
    }

    .report-header h3,
    .report-header h6 {
      margin: 0;
      text-transform: capitalize;
    }

    .report-header {
      margin-bottom: 1rem;
    }

    table {
      width: 100%;
    }

    .table th,
    .table td {
      font-size: 10px;
      vertical-align: middle;
    }

    .table th {
      background-color: #f8f9fa;
    }

    .text-small {
      font-size: 10px;
      color: #555;
    }

    @media print {
      body {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .table th {
        background-color: #f1f1f1 !important;
      }
    }
  </style>
</head>
<body>
  <div class="report-container">
    <!-- Header Section -->
    <div class="text-center report-header text-center text-capitalize">
      <h3>Dr. <%= patients[0].DoctorFirstName %> <%= patients[0].DoctorLastName %></h3>
      <h6 class="mb-1"><%= patients[0].Degree1 %> <%= patients[0].Degree2 %> <%= patients[0].Degree3 %></h6>
      <h6 class="mb-1"><%= patients[0].Degree4 %> - <%= patients[0].SpecialistIn %></h6>
      <h6 class="text-muted"><%= patients[0].WorkedAt %></h6>
    </div>

    <hr class="my-3">

    <!-- Table Section -->
    <div class="table-responsive">
      <table class="table table-bordered table-striped align-middle text-wrap">
        <thead class="text-center">
          <tr>
            <th>#</th>
            <th>Patient Name</th>
            <th>Test(s)</th>
            <th>Date</th>
            <th>Gross Fee</th>
            <th>Discount</th>
            <th>Dues</th>
            <th>Thanks</th>
          </tr>
        </thead>
        <tbody>
          <% let i = 1; patients.forEach(patient => { %>
            <tr>
              <td class="text-center"><%= i %></td>
              <td>
                <strong><%= patient.Name %></strong><br>
                <div class="text-small"><%= patient.Age %> <%= patient.YMD %> | <%= patient.Gender %></div>
              </td>
              <td>
                <%= patient.TestNames %><br>
                <div class="text-small"><%= patient.SubTestNames %></div>
              </td>
              <td class="text-center"><%= new Date(patient.RegisteredOn).toLocaleDateString() %></td>
              <td class="text-end"><%= patient.GrossAmount %></td>
              <td class="text-end"><%= patient.Discount %></td>
              <td class="text-end"><%= patient.DuesAmount %></td>
              <td class="text-end"><%= patient.TotalThanks %></td>
            </tr>
          <% i++; }); %>
        </tbody>
        <tfoot>
          <tr class="fw-bold">
            <td colspan="3"></td>
            <td class="text-start">Total</td>
            <td class="text-end"><%= totalGrossFee.toLocaleString() %></td>
            <td class="text-end"><%= totalDiscount %></td>
            <td class="text-end"><%= totalDues %></td>
            <td class="text-end"><%= totalThanks.toLocaleString() %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</body>
</html>

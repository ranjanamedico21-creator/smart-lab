<!DOCTYPE html>
<html>
<head>
    <title>Customer Ledger</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            font-size: 13px;
            background: #f8f9fa;
        }

        .ledger-container {
            max-width: 1100px;
            margin: auto;
            background: #fff;
            padding: 30px;
            box-shadow: 0 0 10px rgba(0,0,0,0.05);
        }

        .report-title {
            font-size: 22px;
            font-weight: 600;
        }

        .company-name {
            font-size: 18px;
            font-weight: 600;
        }

        .customer-block {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 6px;
        }

        .table thead {
            background-color: #212529;
            color: #fff;
        }

        .closing-row {
            background-color: #e9ecef;
            font-weight: 600;
        }

        .totals-box {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 6px;
        }

        @media print {
            .no-print {
                display: none;
            }
            body {
                background: white;
            }
            .ledger-container {
                box-shadow: none;
            }
        }
    </style>
</head>

<body>

    <!-- Print Button -->
    <div class="container mt-3 no-print">
        <div class="text-end">
            <button class="btn btn-primary" onclick="window.print()">
                Print / Download PDF
            </button>
        </div>
    </div>

    <div class="ledger-container mt-3 mb-5">

        <!-- HEADER -->
        <div class="row align-items-center mb-4">
            <div class="col-md-6">
                <div class="report-title">Customer Ledger</div>
                <div class="text-muted">
                    From <strong><%= fromDate %></strong> to <strong><%= toDate %></strong>
                </div>
            </div>

            <div class="col-md-6 text-md-end">
                <img src="<%= imageBase64 %>" class="img-fluid mb-2" style="max-height:60px;">
                <div class="company-name"><%= company.coreCompany %></div>
                <div class="small text-muted">
                    <%= company.coreCompanyAddress %><br>
                    GSTIN: <%= company.coreCompanyGstNo %> |
                    Phone: <%= company.coreCompanyPhoneNumber %><br>
                    DL No: <%= company.coreCompanyDLNo %>
                </div>
            </div>
        </div>

        <!-- CUSTOMER DETAILS -->
        <div class="customer-block mb-4">
            <strong>Customer Name:</strong> <%= customer.CustomerName %><br>
            <%= customer.BillingAddress %>,
            <%= customer.BillingDistrict %>,
            <%= customer.BillingState %> -
            <%= customer.BillingPincode %><br>
            GSTIN: <%= customer.GstNo %><br>
            Generated On: <%= currentDate %>
        </div>

        <!-- LEDGER TABLE -->
        <table class="table table-bordered table-sm align-middle">
            <thead>
                <tr class="text-center">
                    <th style="width:10%">Date</th>
                    <th style="width:28%">Particulars</th>
                    <th style="width:15%">Voucher No</th>
                    <th style="width:10%">Type</th>
                    <th style="width:12%" class="text-end">Debit (₹)</th>
                    <th style="width:12%" class="text-end">Credit (₹)</th>
                    <th style="width:13%" class="text-end">Balance (₹)</th>
                </tr>
            </thead>
            <tbody>

                <% ledger.forEach(function(item, index){ 
                    const isLast = index === ledger.length - 1;
                %>

                <tr class="<%= isLast ? 'closing-row' : '' %>">
                    <td><%= item.Date %></td>
                    <td><%= item.Description %></td>
                    <td><%= item.PaymentNo || '' %></td>
                    <td><%= item.PaymentType || '' %></td>
                    <td class="text-end">
                        <%= item.Debit > 0 ? item.Debit : '' %>
                    </td>
                    <td class="text-end">
                        <%= item.Credit > 0 ? Number(item.Credit).toFixed(2) : '' %>
                    </td>
                    <td class="text-end fw-semibold">
                        <%= item.Balance %>
                    </td>
                </tr>

                <% }) %>

            </tbody>
        </table>

        <!-- TOTALS SECTION -->
        <div class="row mt-4">
            <div class="col-md-6">
                <div class="totals-box">
                    <strong>Bank Details</strong><br>
                    <%= company.coreCompanyBankName %><br>
                    A/C: <%= company.coreCompanyAccountNo %><br>
                    IFSC: <%= company.coreCompanyIFSCCode %>
                </div>
            </div>

            <div class="col-md-6">
                <div class="totals-box text-end">
                    <div><strong>Total Debit:</strong> ₹ <%= totalDebit %></div>
                    <div><strong>Total Credit:</strong> ₹ <%= totalCredit %></div>
                    <hr>
                    <div class="fs-5">
                        <strong>Closing Balance:</strong> ₹ <%= closingBalance %>
                    </div>
                </div>
            </div>
        </div>

        <!-- SIGNATURE -->
        <div class="text-end mt-5">
            For <%= company.coreCompany %><br><br>
            <strong>Authorized Signatory</strong>
        </div>

    </div>

</body>
</html>

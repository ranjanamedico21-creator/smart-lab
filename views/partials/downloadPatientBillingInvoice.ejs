<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">

<title>Invoice</title>

<style>

body{
    font-size:12.5px;
    background:#fff;
}

.invoice-box{
    max-width:850px;
    margin:auto;
}

.brand-title{
    font-weight:700;
    letter-spacing:.5px;
}

.brand-sub{
    font-size:11px;
}

.section-label{
    font-size:11px;
    text-transform:uppercase;
    color:#6c757d;
    font-weight:600;
}

.info-row p{
    margin:2px 0;
}

.table thead{
    background:#f5f7fa;
}

.table td,.table th{
    padding:4px 8px;
}

.total-card{
    background:#f8f9fa;
    border-radius:6px;
    padding:10px;
}

.total-card td{
    padding:2px 6px;
}

.total-final{
    font-size:14px;
    font-weight:700;
}

.watermark{
  position:fixed;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%);
  font-size:120px;
  color:rgba(255,0,0,0.18);
  font-weight:bold;
}

</style>
</head>

<body>

<% if (patientDetails[0].Status === 2) { %>
<div class="watermark">CANCELLED</div>
<% } %>

<div class="container-fluid p-3 invoice-box">

<!-- Header -->

<div class="text-center border-bottom pb-2 mb-3">

<div class="brand-title fs-5">
<%= BRAND_NAME %>
</div>

<div class="brand-sub">
<%= BRAND_QUOTE %>
</div>

<div class="brand-sub">
<%= BRAND_SUB_QUOTE %>
</div>

<div class="brand-sub">
📞 <%= BRAND_CONTACT_NO %> , <%= BRAND_SECONDARY_CONTACT_N0 %>
</div>

</div>


<!-- Info Section -->

<div class="row info-row mb-3">

<div class="col-6">

<div class="section-label mb-1">Patient Details</div>

<p>
<b>Name:</b>
<%= patientDetails[0].Title %>
<%= patientDetails[0].Name %>
</p>

<p>
<b>Age / Sex:</b>
<%= patientDetails[0].Age %><%= patientDetails[0].YMD %> /
<%= patientDetails[0].Gender == 1 ? 'M' : 'F' %>
</p>

<p>
<b>Phone:</b>
<%= patientDetails[0].PhoneNumber %>
</p>

</div>

<div class="col-6 text-end">

<div class="section-label mb-1">Visit Details</div>

<p>
<b>Date:</b>
<%= patientDetails[0].RegisteredOn %>
</p>

<p>
<b>Doctor:</b>
Dr. <%= patientDetails[0].DoctorFirstName %>
<%= patientDetails[0].DoctorLastName %>
</p>

<p>
<b>Degree:</b>
<%= patientDetails[0].DoctorDegree1 %>
<%= patientDetails[0].DoctorDegree2 %>
<%= patientDetails[0].DoctorDegree3 %>
</p>

</div>

</div>


<!-- Test Table -->

<table class="table table-sm align-middle">

<thead>
<tr>
<th style="width:40px">#</th>
<th>Test</th>
<th class="text-end" style="width:120px">Amount</th>
</tr>
</thead>

<tbody>

<% let i=0; testDetails.forEach(function(test){ i++; %>

<tr>

<td><%= i %></td>

<td>
<%= test.TestName %>
</td>

<td class="text-end">
₹ <%= test.Price %>
</td>

</tr>

<% }) %>

</tbody>

</table>


<!-- Totals -->

<div class="row mt-2">

<div class="col-6 align-self-end">

<small class="text-muted">
Thank you for choosing our diagnostic services.
</small>

</div>

<div class="col-6">

<div class="total-card">

<table class="w-100">

<tr>
<td>Subtotal</td>
<td class="text-end">
₹ <%= parseFloat(patientDetails[0].AmountPaid) + parseFloat(DuesAmount) %>
</td>
</tr>

<% if (Discount && Discount != 0) { %>

<tr>
<td>Discount</td>
<td class="text-end">
- ₹ <%= Discount %>
</td>
</tr>

<% } %>

<tr>
<td>Amount Paid</td>
<td class="text-end">
₹ <%= patientDetails[0].AmountPaid %>
</td>
</tr>

<tr class="total-final border-top">

<td>Dues</td>
<td class="text-end">
₹ <%= patientDetails[0].DuesAmount %>
</td>

</tr>

</table>

</div>

</div>

</div>

</div>

</body>
</html>
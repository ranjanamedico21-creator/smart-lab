<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Invoice</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" />

  <style>
    body {
      font-size: 0.85rem;
      line-height: 1;
      margin: 10px;
    }

    p, span, th, td {
      margin: 0;
      padding: 0;
    }

    .table-sm th, .table-sm td {
      padding: 0.25rem;
    }

    hr {
      margin: 0.4rem 0;
    }

    .fw-medium {
      font-weight: 500;
    }

    /* Print-specific styles */
    @media print {
      body {
        font-size: 11px;
        margin: 0;
      }

      .container, .container-fluid {
        max-width: 100%;
        padding: 6px;
      }

      @page {
        size: A4 portrait;
        margin: 8mm;
      }
    }
  </style>
</head>

<body>
  <div class="container-fluid">
    <!-- Header -->
    <div class="text-center mb-1 small lh-sm">
      <h6 class="fw-bold text-uppercase mb-0">process.env.BRAND_NAME</h6>
      <small class="d-block fst-italic text-decoration-underline mb-0">process.env.BRAND_QUOTE</small>
      <small class="d-block fst-italic text-decoration-underline mb-0">process.env.BRAND_SUB_QUOTE</small>
      <small class="d-block mb-0">process.env.BRAND_ADDRESS | process.env.LANDMARK</small>
      <small class="d-block">MOB: process.env.BRAND_CONTACT_NO, process.env.BRAND_SECONDARY_CONTACT_N0</small>
    </div>
    
    <hr>

    <!-- Date & Bill Info -->
    <div class="row mb-1">
      <div class="col">
        <small><strong>Date:</strong> <%= patientDetails[0].RegisteredOn %></small>
      </div>
      <div class="col text-end">
        <small><strong>Time:</strong> <%= patientDetails[0].RegisteredTime %></small>
      </div>
    </div>

    <div class="text-center mb-1">
      <strong class="text-uppercase">Bill No: <%= patientDetails[0].Id %></strong>
    </div>

    <!-- Doctor / Patient Info -->
    <div class="row small mb-1">
      <div class="col">
        <div><strong>Doctor:</strong> <%= patientDetails[0].FirstName %> <%= patientDetails[0].LastName %></div>
        <div><strong>Qualification:</strong> <%= patientDetails[0].Degree1 %> <%= patientDetails[0].Degree2 %></div>
      </div>
      <div class="col text-end">
        <div><strong>Patient:</strong> <%= patientDetails[0].Name %></div>
        <div><strong>Contact:</strong> <%= patientDetails[0].PhoneNumber %></div>
        <div><strong>Age/Sex:</strong> <%= patientDetails[0].Age %>, <%= patientDetails[0].Gender %></div>
        <div><strong>Address:</strong> <%= patientDetails[0].Address %></div>
      </div>
    </div>
    <hr>

    <!-- Tests Table -->
    <table class="table table-sm table-borderless mb-1">
      <thead class="border-bottom">
        <tr>
          <th>#</th>
          <th>Test</th>
          <th class="text-end">Fee</th>
          <th class="text-end">Disc.</th>
        </tr>
      </thead>
      <tbody>
        <% let i = 1; testDetails.forEach(function(test) { %>
        <tr>
          <td><%= i++ %></td>
          <td><%= test.TestName %></td>
          <td class="text-end"><%= test.Price %></td>
          <td class="text-end"><%= test.Discount %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>

    <!-- Totals -->
    <div class="text-end small">
      <div><strong>Actual Amt (Rs.):</strong> <%= patientDetails[0].ActualAmount %></div>
      <div><strong>Discount (Rs.):</strong> <%= patientDetails[0].Discount %></div>
      <hr class="my-1">
      <div><strong>Gross Amt (Rs.):</strong> <%= patientDetails[0].GrossAmount %></div>
      <hr class="my-1">
      <div><strong>Paid (Rs.):</strong> <%= patientDetails[0].AmountPaid %></div>
    </div>
  </div>
</body>
</html>


<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet"
      integrity="sha384-4bw+/aepP/YC94hEpVNVgiZdgIC5+VKNBQNGCHeKRQN+PtmoHDEXuppvnDJzQIu9" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
    <title>Report</title>
  </head>
  <body class="googoose-wrapper">
      <section class="my-3 mx-3">
        <div class="row">
            <div class="col">
                <table class="table">
                      <tbody>
                          <tr>
                            <td><span><b>Patient Name :</b>&nbsp;&nbsp;</span><span><%=patientDetails[0].Title%>&nbsp;<%=patientDetails[0].Name%></span></td>
                            <td><span><b>Age/Sex:</b></span><span><%=patientDetails[0].Age%>&nbsp;&nbsp;<%= patientDetails[0].YMD%><%= patientDetails[0].Gender %></span></td>
                          </tr>
                          <tr>
                            <td><span><b>Ref By:</b></span>&nbsp;&nbsp;
                                <span><%=patientDetails[0].FirstName%><%= patientDetails[0].LastName %></span>
                                <p><%=patientDetails[0].Degree1%>,<%=patientDetails[0].Degree2%></p>
                            </td>
                            <td><span><b>Date:</b></span>&nbsp;&nbsp;<span><%=patientDetails[0].RegisteredOn %></span></td>
                          </tr>
                     </tbody>
                </table>
            </div>
        </div>
      </section>
      <section class=" my-3 mx-3">
        <div class="row">
            <div class="col">
                <%-getReport[0].Report%>   
            </div>
        </div>
      </section>     
  </body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sales Invoice</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f9f9f9;
      font-size: 14px;
      margin: 0;
      padding: 0;
    }

    .invoice-box {
      display: flex;
      flex-direction: column;
      min-height: 95vh;
      background: #fff;
      padding: 20px;
      border-radius: 6px;
    }

    .invoice-header {
      border-bottom: 2px solid #000;
      margin-bottom: 1rem;
    }

    .table th,
    .table td {
      padding: 4px;
      vertical-align: middle;
      border: none !important;
    }

    .table thead th {
      background-color: #f8f9fa;
    }

    .invoice-content {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }

    .items-section {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }

    .table-responsive {
      flex-grow: 1;
    }

    @media print {
      body {
        font-size: 12px;
        color: #000;
      }
      .no-print {
        display: none !important;
      }
      .invoice-box {
        border: none;
        box-shadow: none;
      }
    }
  </style>
</head>
<body>
  <div class="container-fluid my-4 invoice-box">

    <!-- Print Button -->
    <div class="no-print text-end mb-3">
      <button class="btn btn-outline-primary" onclick="window.print()">
        Print / Download PDF
      </button>
    </div>

    <!-- Header -->
    <div class="row invoice-header align-items-center pb-2">
      <div class="col-3">
        <img src="<%=imageBase64%>" alt="Company Logo" class="img-fluid" style="max-height: 60px;">
      </div>
      <div class="col-9 text-end">
        <h4 class="fw-bold mb-1"><%= companyDetails.coreCompany || "Company Name" %></h4>
        <p class="mb-0"><%= companyDetails.coreCompanyAddress || "Company Address" %></p>
        <small>
          Email: <%= companyDetails.coreCompanyEmail || "N/A" %> |
          Phone: <%= companyDetails.coreCompanyPhoneNumber || "N/A" %> |
        </small>
          DLNO: <%= companyDetails.coreCompanyDLNo || "NA" %>
      </div>
    </div>

    <!-- Tax Header -->
    <div class="row text-center bg-light py-2 mb-3 rounded">
      <div class="col">
        <p class="mb-0"><strong>GSTIN:</strong> <%= companyDetails.coreCompanyGstNo || "N/A" %></p>
      </div>
      <div class="col">
        <h5 class="fw-bold text-uppercase">Tax Invoice</h5>
      </div>
      <div class="col">
        <p class="mb-0">Original for Recipient</p>
      </div>
    </div>

    <!-- Customer and Invoice Details -->
    <div class="row mb-3">
      <div class="col-md-7 border-end">
        <h6 class="text-center text-decoration-underline">Customer Details</h6>
        <p>
          <strong>Name:</strong><span class="text-capitalize"><%= customerDetails?.CustomerName || "N/A" %></span> <br>
          <strong>Address:</strong><span class="text-capitalize"><%= customerDetails?.BillingAddress || "N/A" %></span><br>
          <strong>Contact:</strong> <%= customerDetails?.MobileNo || "N/A" %><br>
          <strong>District:</strong> <span class="text-capitalize"><%= customerDetails?.BillingDistrict || "N/A" %></span>,
          <strong>State:</strong> <%= customerDetails?.BillingState || "N/A" %>,
          <strong>Pincode:</strong> <%= customerDetails?.BillingPincode || "N/A" %><br>
          <strong>GST:</strong><span clas="=text-uppercase"><%= customerDetails?.GstNo || "N/A" %></span>,
          <strong>DL:</strong> <span class="text-uppercase"><%= customerDetails?.DlNo || "N/A" %></span>
        </p>
      </div>
      <div class="col-md-5">
        <h6 class="text-center text-decoration-underline">Invoice Details</h6>
        <p>
          <strong>Invoice No.:</strong> <%= invoiceId || "N/A" %><br>
          <strong>Invoice Date:</strong> <%= totalSaleDetails[0]?.CreatedAt || "N/A" %><br>
          <strong>Challan No.:</strong> <%= totalSaleDetails[0]?.ChallanNo || "N/A" %><br>
          <strong>Delivery Date:</strong> <%= totalSaleDetails[0]?.DeliveryDate || "N/A" %>
        </p>
      </div>
    </div>

    <!-- Begin Content Section -->
    <div class="invoice-content">

      <!-- Invoice Items -->
      <div class="items-section mb-3">
        <div class="table-responsive">
          <table class="table table-sm text-center mb-0">
            <thead>
              <tr>
                <th>Sr.</th>
                <th>Product</th>
                <th>HSN/SAC</th>
                <th>Batch</th>
                <th>MRP</th>
                <th>Expiry</th>
                <th>Qty</th>
                <th>Rate</th>
                <th>Taxable</th>
                <th>SGST (%)</th>
                <th>CGST (%)</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              <% salesData.forEach((sales, i) => { %>
                <tr>
                  <td class="fw-bold"><%= i + 1 %>.</td>
                  <td class="text-start"><span class="text-capitalize fw-bold"><%= sales.KnownAs %></span>&nbsp;<span class="text-lowercase"><%= sales.ProductName || "N/A" %></span></td>
                  <td><%= sales.Hsn || "N/A" %></td>
                  <td><%= sales.BatchNumber || "N/A" %></td>
                  <td><%= sales.MRP || "N/A" %></td>
                  <td><%= sales.ExpiryDate || "N/A" %></td>
                  <td><%= sales.QuantitySold || 0 %></td>
                  <td><%= sales.SalePrice || 0 %></td>
                  <td><%= sales.TotalValue || 0 %></td>
                  <td><%= sales.sgst || 0 %></td>
                  <td><%= sales.cgst || 0 %></td>
                  <td><%= sales.TotalValueWithTax || 0 %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
      <hr class="my-2" style="border-top: 1px solid #000;">
      <!-- Bank & Summary -->
      <div class="row mb-3">
        <div class="col-md-6 border-end">
          <h6 class="text-center text-decoration-underline">Bank Details</h6>
          <p>
            <strong>Account Holder:</strong> <%= companyDetails.coreCompany || "N/A" %><br>
            <strong>Bank Name:</strong> <%= companyDetails.coreCompanyBankName || "N/A" %><br>
            <strong>Branch Name:</strong> <%= companyDetails.coreCompanyBranchName || "N/A" %><br>
            <strong>Account Number:</strong> <%= companyDetails.coreCompanyAccountNo || "N/A" %><br>
            <strong>IFSC Code:</strong> <%= companyDetails.coreCompanyIFSCCode || "N/A" %>
          </p>
        </div>
        <div class="col-md-6">
          <h6 class="text-center text-decoration-underline">Summary</h6>
          <p>
            <strong>Taxable Amount:</strong> <%= totalSaleDetails[0]?.TotalValue || 0 %> Rs.<br>
            <strong>Add SGST:</strong> <%= totalSaleDetails[0]?.TotalSgstAmount || 0 %> Rs.<br>
            <strong>Add CGST:</strong> <%= totalSaleDetails[0]?.TotalCgstAmount || 0 %> Rs.<br>
            <strong>Total Tax:</strong> <%= (Number(totalSaleDetails[0]?.TotalSgstAmount || 0) + Number(totalSaleDetails[0]?.TotalCgstAmount || 0)) %> Rs.<br>
            <strong>Total After Tax:</strong> <%= totalSaleDetails[0]?.TotalValueWithTax || 0 %> Rs.
          </p>
        </div>
      </div>
      <hr class="my-2" style="border-top: 1px solid #000;">
      <!-- Terms & Signature -->
      <div class="row mt-3 pt-2">
        <div class="col-md-6">
          <h6 class="text-uppercase">Terms & Conditions</h6>
          <p>
            1. Goods once sold will not be taken back.<br>
            2. All disputes subject to Patna jurisdiction only.<br>
            3. All payments should be made within 30 days of goods received.
          </p>
        </div>
        <div class="col-md-3">
          <h6 class="text-uppercase">Recipient Signatory</h6>
          <br><br>
          <p>(Place for signature)</p>
        </div>
        <div class="col-md-3 text-end">
          <h6 class="text-uppercase">Authorized Signatory</h6>
          <br><br>
          <p>(Place for signature)</p>
        </div>
      </div>

    </div> <!-- end .invoice-content -->

  </div>
</body>
</html>

<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Discount Report
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Form and Table Section -->
<section class="pb-5">
  <div class="container-fluid">
    <!-- Form Card -->
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden mb-4">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-search me-2"></i>Discount Report Search
        </h4>
      </div>
      <div class="card-body p-4">
        <form action="/report/getDiscountReport" method="post">
          <div class="row g-3">
            <div class="col-md-6">
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input type="text" class="form-control" id="name" name="Name" 
                       placeholder="Enter Patient Name" 
                       value="<%= typeof Name!= 'undefined' ? Name : '' %>">
              </div>
            </div>
            <div class="col-md-6">
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person-vcard"></i></span>
                <select name="Doctor" class="form-control" id="doctor" 
                        data-live-search="true" aria-label="select doctor">
                  <option value="" selected>Select a Doctor</option>
                  <%doctorDetails.forEach(function(doctor){ %>
                    <option value="<%=doctor.Id%>" 
                            <% if(typeof doctorId != 'undefined' && doctor.Id == doctorId){%>selected<%}%>>
                      <%=doctor.FirstName%> <%=doctor.LastName%>
                    </option>
                  <%})%>
                </select>
              </div>
            </div>
            <div class="col-md-6">
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                <input type="text" id="FromDate" class="form-control" name="FromDate" 
                       placeholder="From Date" 
                       value="<%= typeof FromDate!= 'undefined' ? FromDate : '' %>" 
                       autocomplete="off">
              </div>
            </div>
            <div class="col-md-6">
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                <input type="text" class="form-control" id="ToDate" name="ToDate" 
                       placeholder="To Date" 
                       value="<%= typeof ToDate!= 'undefined' ? ToDate : '' %>" 
                       autocomplete="off">
              </div>
            </div>
          </div>
          <div class="text-center mt-4">
            <button class="btn btn-primary px-4" type="submit">
              <i class="bi bi-search me-2"></i>Search
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Discount Details Card -->
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-currency-rupee me-2"></i>Discount Details
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include("./partials/messages"); %>
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">
            <thead class="table-primary text-center">
              <tr>
                <th scope="col">#</th>
                <th scope="col">Patient Name</th>
                <th scope="col">Actual Amount</th>
                <th scope="col">Gross Amount</th>
                <th scope="col">Discount</th>
                <th scope="col">Approved By</th>
                <th scope="col">Referred By</th>
                <th scope="col">Date</th>
              </tr>
            </thead>
            <tbody class="pagination-loop">
              <% let i = 1; discountReportDetails.forEach(function(discountReportDetail){ %>
                <tr class="<% if (discountReportDetail.DuesAmount > 0 && discountReportDetail.Status == 1) { %>table-danger<% } %>
                           <% if (discountReportDetail.Status == 2) { %>text-decoration-line-through text-muted<% } %>">
                  <td class="text-center"><%=i%>.</td>
                  <td class="text-capitalize">
                    <a data-bs-toggle="tooltip" data-bs-custom-class="custom-tooltip"
                       data-bs-placement="top" title="<%= discountReportDetail.TestNames %>"
                       href="/patient/getPatientDetail?patientId=<%= discountReportDetail.PatientId %>"
                       class="text-decoration-none fw-semibold text-dark">
                      <i class="bi bi-person-circle text-primary me-1"></i>
                      <%= discountReportDetail.Title %> <%= discountReportDetail.Name %>
                    </a>
                    <div class="text-muted small">
                      <% if(discountReportDetail.Gender == 1) { %>
                        <i class="bi bi-gender-male text-info"></i> Male
                      <% } else { %>
                        <i class="bi bi-gender-female text-danger"></i> Female
                      <% } %>
                      | <%= discountReportDetail.Age %> <%= discountReportDetail.YMD %>
                    </div>
                    <div class="small">
                      <i class="bi bi-phone text-success"></i> +91 <%= discountReportDetail.PhoneNumber %>
                    </div>
                  </td>
                  <td class="text-center">₹<%=discountReportDetail.ActualAmount%></td>
                  <td class="text-center">₹<%=discountReportDetail.GrossAmount%></td>
                  <td class="text-center">₹<%=discountReportDetail.Discount%></td>
                  <td class="text-center text-capitalize"><%=discountReportDetail.DiscountApprovedBy%></td>
                  <td class="text-capitalize text-center">
                    <strong>Dr. <%= discountReportDetail.DoctorFirstName%> <%= discountReportDetail.DoctorLastName %></strong>
                    <div class="small text-muted">
                      <i class="bi bi-clipboard-heart"></i> <%= discountReportDetail.DoctorSpecialistIn %>
                    </div>
                  </td>
                  <td class="text-center">
                    <i class="bi bi-calendar me-1"></i><%=discountReportDetail.RegisteredOn%>
                  </td>
                </tr>
              <% i++})%>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm justify-content-center gap-1 mt-4" id="pagination_Number">
            <li class="page-item disabled">
              <a class="page-link rounded-pill px-3" href="#">Previous</a>
            </li>
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">1</a>
            </li>
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">Next</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</section>
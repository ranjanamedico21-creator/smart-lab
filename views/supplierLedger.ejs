  <section class="py-3">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded shadow-sm">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none text-primary">Home</a></li>
        <li class="breadcrumb-item active fw-semibold text-dark" aria-current="page">Supplier Ledger</li>
      </ol>
    </nav>
  </section>
  
  <section class="py-2">
    <div class="container-fluid">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="text-center mb-3">Supplier Ledger</h4>
  
          <%- include("./partials/messages"); %>
  
          <form action="/billing/supplierLedger/<%= supplierDetails[0].Id %>" method="post">
            <div class="row g-3 align-items-end">
              <div class="col-md-3">
                <label for="financialYear" class="form-label">Financial Year</label>
                <select id="financialYear" name="financialYear" data-selected="<%= typeof financialYear!= 'undefined' ? financialYear : '' %>" class="form-control">
                </select>
              </div>
  
              <div class="col-md-5">
                <div class="btn-group w-100" role="group">
                  <button type="button" class="btn btn-outline-secondary quick-filter" data-filter="currentFY">Current FY</button>
                  <button type="button" class="btn btn-outline-secondary quick-filter" data-filter="lastFY">Last FY</button>
                  <button type="button" class="btn btn-outline-secondary quick-filter" data-filter="last3Months">Last 3 Months</button>
                </div>
              </div>
  
              <div class="col-md-2">
                <label for="FromDate" class="form-label">From Date</label>
                <input type="text" name="startDate" id="FromDate" class="form-control datepicker" value="<%= startDate || '' %>" autocomplete="off" placeholder="Start Date">
              </div>
  
              <div class="col-md-2">
                <label for="ToDate" class="form-label">To Date</label>
                <input type="text" name="endDate" id="ToDate" class="form-control datepicker" value="<%= endDate || '' %>" autocomplete="off" placeholder="End Date">
              </div>
  
              <div class="col-md-12 text-end">
                <button type="submit" class="btn btn-primary mt-2"><i class="bi bi-filter-circle"></i> Apply Filter</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
  
  <section class="py-3">
    <div class="container">
      <div class="card shadow-sm border-0">
        <div class="card-body">
  
          <h5 class="mb-3 text-center">Supplier Details</h5>
  
          <% if (supplierDetails) { %>
            <div class="row mb-4">
              <div class="col-md-6">
                <p><strong>Address:</strong> <%= supplierDetails[0].Address %>, <%= supplierDetails[0].City %>, <%= supplierDetails[0].State %>, <%= supplierDetails[0].Pincode %></p>
                <p><strong>Contact:</strong> <%= supplierDetails[0].ContactNo %></p>
                <p class="text-uppercase"><strong>GSTIN:</strong> <%= supplierDetails[0].GstNo %></p>
                <p class="text-uppercase"><strong>DL No:</strong> <%= supplierDetails[0].DlNo %></p>
              </div>
              <div class="col-md-2">
                <a href="/billing/getSupplierList" class="btn btn-outline-primary" target="_blank"><i class="bi bi-people-fill"></i> Supplier List</a>
              </div>
              <div class="col-md-2">
                <a href="/billing/downloadSupplierLedgerInExcel/<%= supplierDetails[0].Id%>/<%=startDate%>/<%=endDate%>" class="btn btn-success" target="_blank">
                  <i class="bi bi-file-earmark-excel"></i> Download Excel
                </a>
              </div>
              <div class="col-md-2">
                <a href="/billing/addPaymentToSupplier" class="btn btn-success" target="_blank">
                  <i class="bi bi-file-earmark-rupee"></i> Add Payment
                </a>
              </div>
            </div>
          <% } %>
  
          <div class="table-responsive">
            <table class="table table-striped table-hover align-middle text-center">
              <thead class="table-light">
                <tr>
                  <th>Date</th>
                  <th>PoDate</th>
                  <th>Description</th>
                  <th>Debit (₹)</th>
                  <th>Credit (₹)</th>
                  <th>Balance</th>
                </tr>
              </thead>
              <tbody>
                <% if (supplierLedger && supplierLedger.length > 0) { %>
                  <% supplierLedger.forEach((entry) => { %>
                    <tr>
                      <td class="text-nowrap"><%= entry.Date %></td>
                      <td class="text-nowrap"><%= entry.PoDate %></td>
                    
                      <td class="text-start">
                        <%= entry.Description %>
                      </td>
                    
                      <td class="text-end text-danger">
                        <%= entry.Debit > 0 ? entry.Debit.toFixed(2) : '-' %>
                      </td>
                    
                      <td class="text-end text-success">
                        <%= entry.Credit > 0 ? entry.Credit.toFixed(2) : '-' %>
                      </td>
                    
                      <td class="text-end fw-semibold">
                        <span class="<%= entry.Balance.includes('DR') ? 'text-danger' : 'text-success' %>">
                          <%= entry.Balance %>
                        </span>
                      </td>
                    </tr>
                    
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-muted">No transactions found for this supplier</td>
                  </tr>
                <% } %>
              </tbody>
              <tfoot>
                <tr class="table-light fw-semibold">
                  <td colspan="2" class="text-end">Total</td>
                  <td class="text-end text-danger"><%= totalDebit.toFixed(2) %></td>
                  <td class="text-end text-success"><%= totalCredit.toFixed(2) %></td>
                  <td></td>
                </tr>
              
                <tr class="table-secondary fw-bold">
                  <td colspan="4" class="text-end">Closing Balance</td>
                  <td class="text-end <%= closingBalance.includes('DR') ? 'text-danger' : 'text-success' %>">
                    <%= closingBalance %>
                  </td>
                </tr>
              </tfoot>
              
            </table>
          </div>
  
        </div>
      </div>
    </div>
  </section>
  
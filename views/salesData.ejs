<section>
  <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item active text-dark" aria-current="page">Sales Data Trasaction</li>
    </ol>
  </nav>
</section>

<section>
  <div class="container-fluid mt-3 bg-white rounded border p-4">
      <div class="row">
          <div class="col">
              <h4>Sales Data</h4>
          </div>
      </div>
      <div class="row">
          <div class="col">
              <table class="table table-bordered">
                  <thead>
                      <tr>
                          <th>ID</th>
                          <th>Customer</th>
                          <th>Product</th>
                          <th>Batch</th>
                          <th>Quantity</th>
                          <th>Sale Price</th>
                          <th>CGST (%)</th>
                          <th>SGST (%)</th>
                          <th>Total Value</th>
                          <th>Sale Date</th>
                      </tr>
                  </thead>
                  <tbody>
                      <% sales.forEach(sale => { %>
                      <tr>
                          <td><%= sale.Id %></td>
                          <td><%= sale.CustomerName %></td>
                          <td><%= sale.ProductName %></td>
                          <td><%= sale.BatchNumber %></td>
                          <td><%= sale.QuantitySold %></td>
                          <td><%= sale.SalePrice %></td>
                          <td><%= sale.Cgst %></td>
                          <td><%= sale.Sgst %></td>
                          <td><%= sale.TotalValue %></td>
                          <td><%= new Date(sale.CreatedAt).toLocaleString() %></td>
                      </tr>
                      <% }); %>
                  </tbody>
              </table>
          </div>
      </div>
  </div>
</section>
<section class="pb-4 mt-3">
  <nav aria-label="Page navigation">
    <div class="container">
      <div class="d-flex justify-content-center">
        <div class="w-100 overflow-auto">
          <ul class="pagination pagination-sm gap-1 mt-4 flex-nowrap justify-content-center overflow-auto" id="pagination_Number" style="white-space: nowrap; scroll-behavior: smooth;">
            <li class="page-item disabled">
              <a class="page-link rounded-pill px-3 prev_link" href="#">Previous</a>
            </li>
            <!-- Page numbers will be inserted here via JavaScript -->
            <li class="page-item">
              <a class="page-link rounded-pill px-3 next_link" href="#">Next</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </nav>
</section>



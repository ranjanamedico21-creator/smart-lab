<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Display Doctor Thanks List
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Search and List Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-person-check me-2"></i>Doctor Thanks List
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include ("./partials/messages"); %>

        <!-- Search Form -->
        <form action="/doctor/getDoctorThanks" method="post" class="mb-4">
          <div class="row g-3">
            <div class="col-12 col-sm-6 col-md-4">
              <select
                name="Doctor"
                class="form-control"
                id="doctors"
                data-live-search="true"
                aria-label="Select doctor with live search"
              >
                <option value="" selected>Select a Doctor</option>
                <% doctorDetails.forEach(function(doctor){ %>
                  <option
                    value="<%=doctor.Id%>"
                    <% if(typeof doctorId != 'undefined' && doctor.Id == doctorId){%>selected<%}%>
                  >
                    <%=doctor.FirstName%> <%=doctor.LastName%>
                  </option>
                <%})%>
              </select>
            </div>
            <div class="col-12 col-sm-6 col-md-2">
              <input
                type="text"
                id="FromDate"
                class="form-control"
                name="FromDate"
                placeholder="From Date"
                value="<%= typeof FromDate != 'undefined' ? FromDate : '' %>"
                autocomplete="off"
              />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
              <input
                type="text"
                id="ToDate"
                class="form-control"
                name="ToDate"
                placeholder="To Date"
                value="<%= typeof ToDate != 'undefined' ? ToDate : '' %>"
                autocomplete="off"
              />
            </div>
            <div class="col-12 col-sm-6 col-md-2">
              <button class="btn btn-primary w-100 py-2" type="submit">Search</button>
            </div>
            <div class="col-12 col-sm-6 col-md-2">
              <a
                href="/doctor/downloadAllDoctorThanks/<%=FromDate%>/<%=ToDate%>"
                class="btn btn-primary w-100 py-2"
                role="button"
              >
                Download
              </a>
            </div>
          </div>
        </form>

        <!-- Patient List Table -->
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">
            <thead class="table-primary">
              <tr>
                <th scope="col">#</th>
                <th scope="col">Doctor Name</th>
                <th scope="col">Clinic Name</th>
                <th scope="col">Gross Thanks</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody class="pagination-loop">
              <% let i = 1; doctorThanksData.forEach(function (doctor) { %>
                <tr>
                  <td><%=i %></td>
                  <td>Dr. <%=doctor.FirstName %> <%=doctor.LastName %></td>
                  <td>Clinic Name</td>
                  <td><%=doctor.Thanks%> Rs.</td>
                  <td>
                    <a
                      href="/doctor/downloadIndividualDoctorThanks?doctorId=<%= doctor.DoctorId %>&FromDate=<%= FromDate %>&ToDate=<%= ToDate %>"
                      class="text-primary text-decoration-none"
                      target="_blank"
                    >
                      Print
                    </a>
                  </td>
                </tr>
              <% i++ }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm justify-content-center gap-1 mt-4" id="pagination_Number">
            <li class="page-item disabled">
              <a class="page-link rounded-pill px-3" href="#">Previous</a>
            </li>
            <!-- Dynamic pagination numbers can be added here via JS -->
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">1</a>
            </li>
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">Next</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</section>
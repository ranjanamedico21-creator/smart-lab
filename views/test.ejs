    <body>
        <div class="container bg-light border ">
            <!-- Invoice Header -->
            <div class="row mb-2 align-items-center">
                <div class="col">
                    <h4 class="fw-bold mb-0"><%= companyDetails.coreCompany || "Company Name" %></h4>
                    <p class="text-muted mb-0"><%= companyDetails.coreCompanyAddress || "Company Address" %></p>
                    <p class="text-muted mb-0">
                        Email: <%= companyDetails.coreCompanyEmail || "N/A" %> | 
                        Phone: <%= companyDetails.coreCompanyPhoneNumber || "N/A" %>
                    </p>
                </div>
                <div class="col text-end">
                    <img src="<%= companyDetails.logoUrl || 'logo-placeholder.png' %>" alt="Company Logo" class="img-fluid" style="max-height: 80px;">
                </div>
            </div>
            <hr class="border-dark">

            <!-- Invoice Information -->
            <div class="row text-center py-2 bg-secondary text-white">
                <div class="col">
                    <h6>GSTIN: <%= companyDetails.coreCompanyGstNo || "N/A" %></h6>
                </div>
                <div class="col">
                    <h6 class="fw-bold">TAX INVOICE</h6>
                </div>
                <div class="col">
                    <h6>Original for Recipient</h6>
                </div>
            </div>

            <!-- Customer and Invoice Details -->
            <div class="row my-2">
                <div class="col-md-7 border-end">
                    <h6 class="text-center text-uppercase text-decoration-underline">Customer Details</h6>
                    <p>
                        <strong>Name:</strong> <%= customerDetails?.CustomerName || "N/A" %><br>
                        <strong>Address:</strong> <%= customerDetails?.BillingAddress || "N/A" %><br>
                        <strong>Contact:</strong> <%= customerDetails?.MobileNo || "N/A" %><br>
                        <strong>District:</strong> <%= customerDetails?.BillingDistrict || "N/A" %>,
                        <strong>State:</strong> <%= customerDetails?.BillingState || "N/A" %>,
                        <strong>Pincode:</strong> <%= customerDetails?.BillingPincode || "N/A" %><br>
                        <strong>Gst:</strong> <%= customerDetails?.GstNo|| "N/A" %>,
                        <strong>DL:</strong> <%= customerDetails?.DlNo|| "N/A" %><br>
                    </p>
                </div>
                <div class="col-md-5">
                    <h6 class="text-center text-uppercase text-decoration-underline">Invoice Details</h6>
                    <p>
                        <strong>Invoice No.:</strong> <%= invoiceId || "N/A" %><br>
                        <strong>Invoice Date:</strong> <%= totalSaleDetails[0]?.CreatedAt || "N/A" %><br>
                        <strong>Challan No.:</strong> <%= totalSaleDetails[0]?.ChallanNo || "N/A" %><br>
                        <strong>Delivery Date:</strong> <%= totalSaleDetails[0]?.DeliveryDate || "N/A" %>
                    </p>
                </div>
            </div>

            <!-- Invoice Items Table -->
            <div class="row border 1px solid mt-1" style="font-size:14px; min-height:350px">
                <div class="col">
                    <div class="table-responsive">
                        <table class="table">
                            <thead class="table-secondary">
                                <tr>
                                    <th style="width: 5%;">Sr.</th>
                                    <th style="width: 20%;">Product</th>
                                    <th style="width: 10%;">HSN / SAC</th>
                                    <th style="width: 10%;">Batch</th>
                                    <th style="width: 7%;">Qty</th>
                                    <th style="width: 10%;">Rate</th>
                                    <th style="width: 12%;">Taxable Value</th>
                                    <th style="width: 8%;">SGST (%)</th>
                                    <th style="width: 8%;">CGST (%)</th>
                                    <th style="width: 12%;">Total With Tax</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% salesData.forEach((sales, i) => { %>
                                <tr>
                                    <td><%= i + 1 %></td>
                                    <td><%= sales.ProductName || "N/A" %></td>
                                    <td><%= sales.Hsn || "N/A" %></td>
                                    <td><%= sales.BatchNumber || "N/A" %></td>
                                    <td><%= sales.QuantitySold || 0 %></td>
                                    <td><%= sales.SalePrice || 0 %></td>
                                    <td><%= sales.TotalValue || 0 %></td>
                                    <td><%= sales.sgst || 0 %></td>
                                    <td><%= sales.cgst || 0 %></td>
                                    <td><%= sales.TotalValueWithTax || 0 %></td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            
            <!-- Bank and Summary Details -->
            <div class="row mt-1">
                <div class="col-md-6 border-end border-bottom">
                    <h6 class="text-center text-uppercase text-decoration-underline">Bank Details</h6>
                    <p>
                        <strong>Bank Name:</strong> <%= companyDetails.coreCompanyBankName || "N/A" %><br>
                        <strong>Branch Name:</strong> <%= companyDetails.coreCompanyBranchName || "N/A" %><br>
                        <strong>Account Number:</strong> <%= companyDetails.coreCompanyAccountNo || "N/A" %><br>
                        <strong>IFSC Code:</strong> <%= companyDetails.coreCompanyIFSCCode || "N/A" %>
                    </p>
                </div>
                <div class="col-md-6 border-bottom 1px">
                    <h6 class="text-center text-uppercase text-decoration-underline">Summary</h6>
                    <p>
                        <strong>Taxable Amount:</strong> <%= totalSaleDetails[0]?.TotalValue || 0 %>&nbsp;Rs.<br>
                        <strong>Add SGST:</strong> <%= totalSaleDetails[0]?.TotalSgstAmount || 0 %>&nbsp;Rs.<br>
                        <strong>Add CGST:</strong> <%= totalSaleDetails[0]?.TotalCgstAmount || 0 %>&nbsp;Rs.<br>
                        <strong>Total Tax:</strong> <%= (Number(totalSaleDetails[0]?.TotalSgstAmount || 0) + Number(totalSaleDetails[0]?.TotalCgstAmount || 0)) %>&nbsp;Rs.<br>
                        <strong>Total After Tax:</strong> <%= totalSaleDetails[0]?.TotalValueWithTax || 0 %>&nbsp;Rs.
                    </p>
                </div>
            </div>
            <!-- Terms and Conditions -->
            <div class="row mt-1">
                <div class="col-md-8 border-end">
                    <h6 class="text-uppercase text-decoration-underline">Terms and Conditions</h6>
                    <ol>
                        <li> Subject to Patna Jurisdiction.</li>
                        <li> Goods once sold are non-returnable.</li>
                        <li> Delivery is ex-premises.</li>
                        <li> Payment within 30 days of Invoice generated.</li>
                    </ol>
                </div>
                <div class="col-md-4 text-center mt-4">
                    <h6 class="text-uppercase">Authorized Signatory</h6>
                    <p>(Place for signature)</p>
                </div>
            </div>
        </div>
    </body>
</html>



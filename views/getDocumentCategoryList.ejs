
    <!-- Breadcrumb Section -->
    <section class="py-3 py-md-4">
        <div class="container-fluid">
            <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
                <ol class="breadcrumb mb-0 d-flex align-items-center">
                    <li class="breadcrumb-item">
                        <a href="/user/home" class="text-decoration-none text-primary fw-medium">
                            <i class="bi bi-house me-1"></i>Home
                        </a>
                    </li>
                    <li class="breadcrumb-item active fw-semibold text-dark" aria-current="page">
                        Document Category Details
                    </li>
                </ol>
            </nav>
        </div>
    </section>

    <!-- Main Content Section -->
    <section class="pb-5">
        <div class="container-fluid">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0 fw-semibold">
                        <i class="bi bi-folder-fill me-2"></i>Document Category Details
                    </h4>
                    <small class="text-white opacity-75">View and manage document categories</small>
                </div>

                <div class="card-body p-4">
                    <%- include ("./partials/messages"); %>

                    <!-- Responsive Table -->
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="fw-semibold">#</th>
                                    <th scope="col" class="fw-semibold">Category Name</th>
                                    <th scope="col" class="fw-semibold">Created By</th>
                                    <th scope="col" class="fw-semibold">Created On</th>
                                    <th scope="col" class="fw-semibold">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% i = 1; DocumentCategoryDetails.forEach(function(category) { %>
                                <tr class="text-capitalize">
                                    <th scope="row"><%= i %></th>
                                    <td><%= category.Name %></td>
                                    <td><%= category.FirstName %>&nbsp;<%= category.LastName %></td>
                                    <td><%= category.CreatedOn %></td>
                                    <td>
                                        <a href="/category/editDocumentCategory/<%= category.Id %>" class="btn btn-sm btn-primary rounded-3 shadow-sm">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </a>
                                        
                                    </td>
                                </tr>
                                <% i++; }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pagination Section -->
    <section class="pb-4">
        <div class="container">
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm justify-content-center">
                    <li class="page-item disabled">
                        <a class="page-link rounded-3" href="#" tabindex="-1" aria-disabled="true">Previous</a>
                    </li>
                    <ul class="pagination pagination-sm d-inline-flex" id="pagination_Number">
                        <!-- Pagination numbers will be injected here via JavaScript -->
                    </ul>
                    <li class="page-item">
                        <a class="page-link rounded-3" href="#">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    </section>
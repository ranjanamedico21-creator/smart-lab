<!-- Breadcrumb Section -->
<section class="py-4 bg-light">
    <div class="container-fluid">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item">
            <a href="/user/home" class="text-decoration-none text-primary">Home</a>
          </li>
          <li class="breadcrumb-item active text-dark" aria-current="page">Customer Ledger</li>
        </ol>
      </nav>
    </div>
  </section>
  
  <!-- Customer Ledger Table -->
  <div class="container mt-4">
    <div class="card shadow-sm">
      <div class="card-header d-flex justify-content-between align-items-center bg-primary text-white">
        <h5 class="mb-0">Customer Ledger</h5>
        <small>Report Date: <%= moment().format('DD-MM-YYYY') %></small>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table id="customerLedgerTable" class="table table-hover align-middle mb-0">
            <thead class=" text-center">
              <tr>
                <th>#</th>
                <th>Customer Name</th>
                <th>Total Sales (₹)</th>
                <th>Total Payments (₹)</th>
                <th>Pending Amount (₹)</th>
                <th>Last Payment Date</th>
                <th>Include in Total</th>
              </tr>
            </thead>
            <tbody>
              <% if (customersWithDues.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center text-muted py-3">No customers found.</td>
                </tr>
              <% } else { %>
                <% customersWithDues.forEach((cust, index) => { %>
                  <tr class="<%= cust.PendingAmount > 0 ? 'table-warning' : '' %>">
                    <td class="text-center"><%= index + 1 %></td>
                    <td><%= cust.CustomerName %></td>
                    <td class="text-end" data-sales="<%= cust.TotalSales %>">₹ <%= cust.TotalSales.toFixed(2) %></td>
                    <td class="text-end" data-payments="<%= cust.TotalPayments %>">₹ <%= cust.TotalPayments.toFixed(2) %></td>
                    <td class="text-end fw-bold <%= cust.PendingAmount > 0 ? 'text-danger' : 'text-success' %>" data-pending="<%= cust.PendingAmount %>">
                      ₹ <%= cust.PendingAmount.toFixed(2) %>
                    </td>
                    <td class="text-center">
                      <%= cust.LastPaymentDate ? moment(cust.LastPaymentDate).format('DD-MM-YYYY') : '-' %>
                    </td>
                    <td class="text-center">
                      <input type="checkbox" class="include-total" checked>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
            <tfoot>
              <tr id="totalsRow" class="table-secondary fw-bold text-end">
                <td colspan="2" class="text-center">TOTAL</td>
                <td class="total-sales">₹ 0.00</td>
                <td class="total-payments">₹ 0.00</td>
                <td class="total-pending">₹ 0.00</td>
                <td colspan="2"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  </div>
  
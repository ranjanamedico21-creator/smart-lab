<!-- Breadcrumb Section -->
<section class="py-4">
    <div class="container-fluid">
        <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded-3 shadow-sm border">
            <ol class="breadcrumb mb-0 fw-medium">
                <li class="breadcrumb-item">
                    <a href="/categories" class="text-decoration-none text-primary">Categories</a>
                </li>
                <li class="breadcrumb-item active text-dark" aria-current="page">Edit Category</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Edit Category Section -->
<section class="pb-5">
    <div class="container-fluid">
        <div class="card shadow border-0 rounded-4 bg-white overflow-hidden">
            <div class="card-header bg-gradient bg-primary text-white text-center py-3">
                <h4 class="mb-0 fw-bold">Edit Category</h4>
            </div>
            <div class="card-body p-4">
                <!-- Include Flash Messages -->
                <%- include("./partials/messages"); %>

                <!-- Edit Category Form -->
                <form action="/category/updateCategory/<%= categoryDetails.Id %>" class="needs-validation" method="post" novalidate>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6 col-12">
                            <label for="category" class="form-label fw-medium">Category Name</label>
                            <input type="text" 
                                   class="form-control text-capitalize rounded-3" 
                                   value="<%= categoryDetails.Name ? categoryDetails.Name : '' %>" 
                                   aria-label="Enter Category Name"
                                   name="category" 
                                   id="category" 
                                   placeholder="Enter Category Name" 
                                   required>
                            <div class="invalid-feedback">Please enter a valid category name.</div>
                        </div>
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-medium mt-3 mb-3">
                            Update Category
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
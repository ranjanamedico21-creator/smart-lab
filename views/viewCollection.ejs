<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          View Daily Cash Collection
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Collection Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-cash-stack me-2"></i>View Collection
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include ("./partials/messages"); %>

        <!-- Search Form -->
        <form action="/report/viewCollection" method="post" class="mb-4">
          <div class="row g-3 align-items-end">
            <!-- From Date -->
            <div class="col-md-5">
              <label for="FromDate" class="form-label fw-bold text-dark">From Date:</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                <input
                  type="text"
                  id="FromDate"
                  class="form-control"
                  name="FromDate"
                  placeholder="Select From Date"
                  value="<%= typeof FromDate != 'undefined' ? FromDate : '' %>"
                  autocomplete="off"
                />
              </div>
            </div>

            <!-- To Date -->
            <div class="col-md-5">
              <label for="ToDate" class="form-label fw-bold text-dark">To Date:</label>
              <div class="input-group">
                <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                <input
                  type="text"
                  id="ToDate"
                  class="form-control"
                  name="ToDate"
                  placeholder="Select To Date"
                  value="<%= typeof ToDate != 'undefined' ? ToDate : '' %>"
                  autocomplete="off"
                />
              </div>
            </div>

            <!-- Search Button -->
            <div class="col-md-2">
              <button type="submit" class="btn btn-primary w-100 py-2">
                <i class="bi bi-search me-2"></i>Search
              </button>
            </div>
          </div>
        </form>

        <!-- Collection Cards -->
        <div class="row g-3 mb-4">
          <% collections.forEach(function(collection){ %>
            <div class="col-md-6 col-lg-3">
              <div class="card shadow-sm">
                <div class="card-body text-center">
                  <h5 class="card-title text-capitalize fw-bold">
                    <%=collection.FirstName%> <%=collection.LastName%>
                  </h5>
                  <hr />
                  <p class="card-text text-start">
                    <strong>Gross Collection:</strong> <%= Number(collection.cashPayment) +
                    Number(collection.onlinePayment) %> Rs.
                  </p>
                  <p class="card-text text-start">
                    <strong>Returned Amount:</strong> <%=collection.Debit%> Rs.
                  </p>
                  <p class="card-text text-start">
                    <strong>Cash Collection:</strong> <%=collection.cashPayment%> Rs.
                  </p>
                  <p class="card-text text-start">
                    <strong>Online Payment:</strong> <%=collection.onlinePayment%> Rs.
                  </p>
                </div>
              </div>
            </div>
          <%})%>
        </div>

        <!-- Collection Report -->
        <div class="row">
          <div class="col table-responsive">
            <h5 class="fw-bold mb-3">Collection Report</h5>
              <table class="table table-striped table-hover align-middle">
                <tbody>
                  <tr>
                    <td><strong>Total Collection</strong></td>
                    <td><%= totalCollection[0].ActualAmount %> Rs.</td>
                  </tr>
                  <tr>
                    <td><strong>Total Dues</strong></td>
                    <td><%= totalCollection[0].DuesAmount %> Rs.</td>
                  </tr>
                  <tr>
                    <td><strong>Total Discount</strong></td>
                    <td><%= totalCollection[0].Discount %> Rs.</td>
                  </tr>
                  <tr>
                    <td><strong>Total Online Collection</strong></td>
                    <td>
                      <%= Number(totalCollection[0].onlinePayment) +
                      Number(totalDuesReceived[0].duesReceivedAsOnline) %> Rs.
                    </td>
                  </tr>
                  <tr>
                    <td><strong>Total Dues Collection</strong></td>
                    <td>
                      <%= Number(totalDuesReceived[0].duesReceivedAsCash) +
                      Number(totalDuesReceived[0].duesReceivedAsOnline) %> Rs.
                      (Cash: <%= totalDuesReceived[0].duesReceivedAsCash %> Rs. | Online: <%=
                      Number(totalDuesReceived[0].duesReceivedAsOnline) %> Rs.)
                    </td>
                  </tr>
                  <tr>
                    <td><strong>Total Cash Collection</strong></td>
                    <td><%= totalCollection[0].cashPayment %> Rs.</td>
                  </tr>
                </tbody>
              </table>
          </div>
          <div class="col">
            <h5 class="fw-bold mb-3">Cancelled Patient Details</h5>
            <% if (cancelledPatientDetails.length > 0) { %>
                <table class="table table-hover">
                  <thead>
                      <tr>
                          <th>Patient Name</th>
                          <th>Amount Ret</th>
                          <th>Cancelled On</th>
                          <th>Registered On</th>
                      </tr>
                  </thead>
                  <tbody>
                      <% cancelledPatientDetails.forEach(patient => { %>
                          <tr class="text-capitalize">
                              <td><a href="/patient/getPatientDetail/?patientId=<%=patient.Id %>"><%= patient.Name %></a></td>
                              <td><%= patient.TotalPaymentReturned %>Rs.</td>
                              <td><%= patient.CancelledOn %></td>
                              <td><%= patient.RegisteredOn %></td>
                          </tr>
                      <% }) %>
                  </tbody>
                </table>
                 <!-- Display Total Amount -->
              <div class="mt-3">
                <h5 class="fw-bold">Total Amount Returned:<%= totalAmountReturned %> Rs.</h5>
            </div>

              <% } else { %>
                <!-- No Data Message -->
                <div class="alert alert-warning text-center" role="alert">
                    No cancelled patients found.
                </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

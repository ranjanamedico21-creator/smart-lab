<!-- Breadcrumb Section -->
<section class="py-4">
    <div class="container-fluid">
      <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
        <ol class="breadcrumb mb-0 d-flex align-items-center">
          <li class="breadcrumb-item">
            <a href="/user/home" class="text-decoration-none text-primary fw-medium">
              <i class="bi bi-house me-1"></i>Home
            </a>
          </li>
          <li class="breadcrumb-item active fw-bold" aria-current="page">
            Create Document
          </li>
        </ol>
      </nav>
    </div>
  </section>
  
  <!-- Main Content Section -->
  <section class="pb-5">
    <div class="container-fluid">
      <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
        <div class="card-header bg-primary text-white text-center py-3">
          <h4 class="mb-0 fw-bold">
            <i class="bi bi-folder-plus me-2"></i>Create Category
          </h4>
          <small class="text-white opacity-75">Add a new document category</small>
        </div>
  
        <div class="card-body p-4">
          <%- include("./partials/messages"); %>
  
          <!-- Form Section -->
          <form
            action="/category/createDocumentCategory"
            class="needs-validation"
            method="post"
            novalidate
          >
            <div class="row">
              <div class="col-12 col-md-8 col-lg-6">
                <div class="form-floating">
                  <input
                    type="text"
                    class="form-control text-capitalize"
                
                    name="category"
                    id="category"
                    placeholder="Enter Document Category Name"
                    required
                    maxlength="50"
                    aria-describedby="documentCategoryHelp"
                  />
                  <label for="category">Category Name</label>
                  <div class="invalid-feedback">Please provide a valid category name.</div>
                  <small id="documentCategoryHelp" class="form-text text-muted d-block mt-1">
                    Enter a unique category name (max 50 characters)
                  </small>
                </div>
              </div>
            </div>
  
            <div class="text-center mt-4">
              <button type="submit" class="btn btn-primary px-5 py-2">
                <i class="bi bi-plus-circle me-2"></i>Create Category
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
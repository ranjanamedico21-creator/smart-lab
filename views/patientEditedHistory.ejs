  <div class="container-fluid">
    <h2>Current Patient Details</h2>
    <table class="table table-responsive table-striped">
      <thead>
            <tr>
                <th>#</th>
                <th class="font-monospace">Patient Detail</th>
                <th class="font-monospace">Referred By</th>
                <th class="font-monospace">Gross Amount</th>
                <th class="font-monospace">Date</th>
                <th class="font-monospace">Status</th>
                <th class="font-monospace">Action</th>
            </tr>
      </thead>
      <tbody id="currentPatientDetails">
        <tbody class="pagination-loop">
            <% i=1;patientDetails.forEach(function(patient){ %>
            <tr <% if(patient.DuesAmount>0){%>class="table-danger" <%}%>>
              <th scope="row"><%=i%>.</th>
              <td class="text-capitalize">
                <p>
                  <a href="/patient/getPatientDetail?patientId=<%=patient.Id%>" class="link-body-emphasis text-decoration-none"><%=patient.title%> <%=patient.Name%></a> 
                  <span><%=patient.Age%> <%=patient.YMD%> | <%=patient.Gender %></span>
                </p>
                <p><%=patient.PhoneNumber%></p>
              </td>
              <td>
                <p class="text-capitalize">Dr. <%= patient.FirstName%> <%= patient.LastName%></p>
                <p class="text-capitalize"> <%= patient.Degree%></p>
              </td>
              <td><%= patient.GrossAmount%></td>
              <td><%= patient.RegisteredOn%></td>
              <td <% if(patient.Status==2){%>class="text-danger"<%}%>><% if(patient.Status==1){%>Active<%}else{%>Cancelled <%}%></td>
              <td>
              </td>
            </tr>
            <% i++; })%>
          </tbody>
      </tbody>
    </table>

    <h2>Patient Details History</h2>
    <div id="patientHistoryTimeline" class="timeline">
        <table class="table table-responsive table-striped">
            <thead>
                  <tr>
                      <th>#</th>
                      <th class="font-monospace">Patient Detail</th>
                      <th class="font-monospace">Referred By</th>
                      <th class="font-monospace">Gross Amount</th>
                      <th class="font-monospace">Date</th>
                      <th class="font-monospace">Status</th>
                      <th class="font-monospace">Action</th>
                  </tr>
            </thead>
            <tbody id="PatientDetailsHistory">
              <tbody class="pagination-loop">
                  <% i=1;patientDetailHistroy.forEach(function(patient){ %>
                  <tr <% if(patient.DuesAmount>0){%>class="table-danger" <%}%>>
                    <th scope="row"><%=i%>.</th>
                    <td class="text-capitalize">
                      <p>
                        <a href="/patient/getPatientDetail?patientId=<%=patient.Id%>" class="link-body-emphasis text-decoration-none"><%=patient.title%> <%=patient.Name%></a> 
                        <span><%=patient.Age%> <%=patient.YMD%> | <%=patient.Gender %></span>
                      </p>
                      <p><%=patient.PhoneNumber%></p>
                    </td>
                    <td>
                      <p class="text-capitalize">Dr. <%= patient.FirstName%> <%= patient.LastName%></p>
                      <p class="text-capitalize"> <%= patient.Degree%></p>
                    </td>
                    <td><%= patient.GrossAmount%></td>
                    <td><%= patient.RegisteredOn%></td>
                    <td <% if(patient.Status==2){%>class="text-danger"<%}%>><% if(patient.Status==1){%>Active<%}else{%>Cancelled <%}%></td>
                    <td>
                    </td>
                  </tr>
                  <% i++; })%>
                </tbody>
            </tbody>
          </table>
    </div>

    <h2>Test Results</h2>
    <table class="table table-striped">
        <thead>
          <tr>
            <th>#</th>
            <th>Test Name</th>
           
            <th>Price</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody class="pagination-loop">
          <% i=1; patientTestDetail.forEach(function(test){ %>
            <tr>
              <th scope="row"><%= i %>.</th>
              <td><%= test.TestName %></td>
             
              <td><%= test.Price %></td>
              <td>
               
              </td>   
            </tr>
          <% i++ }) %>
        </tbody>
      </table>

    <h2>Test Results History</h2>
    <div id="testHistoryTimeline" class="timeline">
        <table class="table table-striped">
            <thead>
              <tr>
                <th>#</th>
                <th>Test Name</th>
               
                <th>Price</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody class="pagination-loop">
              <% i=1; patientTestHistoryDetail.forEach(function(test){ %>
                <tr>
                  <th scope="row"><%= i %>.</th>
                  <td><%= test.TestName %></td>
                 
                  <td><%= test.Price %></td>
                  <td>
                   
                  </td>   
                </tr>
              <% i++ }) %>
            </tbody>
          </table>
    
    </div>
  </div>


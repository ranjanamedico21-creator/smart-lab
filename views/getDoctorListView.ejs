<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Doctor List
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Doctor List Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-person-vcard me-2"></i>Doctor Details
        </h4>
      </div>
      <div class="card-body p-4">
        <!-- Include partials for messages -->
        <%- include("./partials/messages"); %>

        <!-- Responsive table -->
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">
            <thead class="table-primary text-center">
              <tr>
                <th scope="col">#</th>
                <th scope="col">Doctor Name</th>
                <th scope="col">Degree</th>
                <th scope="col">Specialist In</th>
                <th scope="col">Worked At</th>
                <th scope="col">Experience</th>
                <th scope="col">Registration</th>
                <th scope="col">Award</th>
                <th scope="col">Instruction</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody class="pagination-loop">
              <% let i = 1; doctorDetails.forEach(function (doctor) { %>
                <tr>
                  <td class="text-center"><%= i %>.</td>
                  <td class="text-capitalize text-nowrap">
                    <a
                      href="/doctor/getDoctorDetail?doctorId=<%= doctor.Id %>"
                      class="text-decoration-none fw-semibold text-dark"
                    >
                      <i class="bi bi-person-circle text-primary"></i> Dr. <%= doctor.FirstName %>
                      <%= doctor.LastName %>
                    </a>
                  </td>
                  <td
                    class="text-capitalize text-truncate"
                    style="max-width: 180px;"
                    data-bs-toggle="tooltip"
                    data-bs-custom-class="custom-tooltip"
                    data-bs-placement="top"
                    title="<%= doctor.Degree1 %> <%= doctor.Degree2 %> <%= doctor.Degree3 %> <%= doctor.Degree4 %>"
                  >
                    <%= doctor.Degree1 %> <%= doctor.Degree2 %> <%= doctor.Degree3 %> <%= doctor.Degree4 %>
                  </td>
                  <td class="text-capitalize text-center"><%= doctor.SpecialistIn %></td>
                  <td class="text-capitalize text-center"><%= doctor.WorkedAt %></td>
                  <td class="text-center"><%= doctor.YearOfExperience %> years</td>
                  <td class="text-capitalize text-center"><%= doctor.Registration %></td>
                  <td class="text-capitalize text-center"><%= doctor.Award %></td>
                  <td class="text-capitalize"><%= doctor.Instruction %></td>
                  <td class="text-capitalize">
                    <a href="/doctor/editDoctor/<%= doctor.Id %>" class="text-decoration-none fw-semibold text-dark">
                      <i class="bi bi-pencil"></i> 
                    </a>
                  </td>
                </tr>
              <% i++ }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm justify-content-center gap-1 mt-4" id="pagination_Number">
            <li class="page-item disabled">
              <a class="page-link rounded-pill px-3" href="#">Previous</a>
            </li>
            <!-- Dynamic pagination numbers can be added here via JS -->
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">1</a>
            </li>
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">Next</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</section>
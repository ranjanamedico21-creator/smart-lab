
<!-- Breadcrumb Section -->
<section class="py-4">
    <div class="container">
      <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded-3 shadow-sm border">
        <ol class="breadcrumb mb-0 fw-medium">
          <li class="breadcrumb-item">
            <a href="/user/home" class="text-decoration-none text-primary">Home</a>
          </li>
          <li class="breadcrumb-item active text-dark" aria-current="page">Add Payment</li>
        </ol>
      </nav>
    </div>
  </section>
  
  <!-- Add Payment Section -->
  <section class="pb-5">
    <div class="container">
      <div class="card shadow border-0 rounded-4 bg-white overflow-hidden">
        <div class="card-header bg-gradient bg-primary text-white text-center py-3">
          <h4 class="mb-0 fw-bold">Add Payment</h4>
        </div>
        <div class="card-body p-4">
          <%- include ("./partials/messages"); %>
          <form action="/billing/addPayment" class="needs-validation" novalidate method="POST">
            <!-- First Row: Customer ID and Payment Date -->
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <label for="customerId" class="form-label fw-semibold">Select Customer</label>
                <select id="customerId" name="customerId" class="form-control" data-live-search="true" required>
                  <option value="">Select a customer</option>
                  <% customers.forEach(customer => { %>
                    <option 
                      <% if(typeof customerId != 'undefined' && customer.Id == customerId){%>selected<%}%> 
                      value="<%= customer.Id %>">
                      <%= customer.CustomerName %>
                    </option>
                  <% }); %>
                </select>
                <div class="invalid-feedback">Please select a customer.</div>
              </div>
              <div class="col-12 col-md-6">
                <label for="paymentDate" class="form-label fw-semibold">Payment Date</label>
                <input 
                  type="text" 
                  id="FromDate" 
                  name="paymentDate" 
                  class="form-control" 
                  value="<%= typeof paymentDate != 'undefined' ? paymentDate : '' %>" 
                  placeholder="e.g., 03-03-2025" autocomplete="off"
                  required>
                <div class="invalid-feedback">Payment date is required.</div>
              </div>
            </div>
  
            <!-- Second Row: Payment No, Amount Paid, and Payment Mode -->
            <div class="row g-3 mt-3">
              <div class="col-12 col-md-4">
                <label for="paymentNo" class="form-label fw-semibold">Payment No</label>
                <input 
                  type="text" 
                  id="paymentNo" 
                  name="paymentNo" 
                  class="form-control" 
                  value="<%= typeof paymentNo != 'undefined' ? paymentNo : '' %>" 
                  required>
                <div class="invalid-feedback">Payment No is required.</div>
              </div>
              <div class="col-12 col-md-4">
                <label for="amountPaid" class="form-label fw-semibold">Amount Paid</label>
                <input 
                  type="number" 
                  step="0.01" 
                  id="amountPaid" 
                  name="amountPaid" 
                  class="form-control" 
                  value="<%= typeof amountPaid != 'undefined' ? amountPaid : '' %>" 
                  placeholder="e.g., 1000.00" 
                  required>
                <div class="invalid-feedback">Amount paid is required.</div>
              </div>
              <div class="col-12 col-md-4">
                <label for="paymentType" class="form-label fw-semibold">Payment Mode</label>
                <select id="paymentType" name="paymentType" class="form-control" required>
                  <option value="">Select a payment mode</option>
                  <option value="Cash">Cash</option>
                  <option value="Card">Card</option>
                  <option value="Online">Online Transfer</option>
                  <option value="Cheque">Cheque</option>
                  <option value="UPI">UPI</option>
                </select>
                <div class="invalid-feedback">Please select a payment mode.</div>
              </div>
            </div>
  
            <!-- Third Row: Submit Button -->
            <div class="row mt-4 mb-3">
              <div class="col text-center">
                <button type="submit" class="btn btn-primary rounded-pill px-5 fw-medium">Add Payment</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

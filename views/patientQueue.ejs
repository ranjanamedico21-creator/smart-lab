<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Patient Queue</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container my-4">
    <h3 class="mb-3">Patient Queue</h3>

    <table class="table table-bordered table-hover align-middle">
      <thead class="table-dark">
        <tr>
          <th>#</th>
          <th>Patient</th>
          <th>Age/Gender</th>
          <th>Status</th>
          <th>Predicted In</th>
          <th>Predicted Out</th>
          <th>Actual In</th>
          <th>Actual Out</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if(queue.length === 0) { %>
          <tr><td colspan="9" class="text-center text-muted">No patients in queue</td></tr>
        <% } else { %>
          <% queue.forEach((p, idx) => { %>
            <tr>
              <td><%= idx+1 %></td>
              <td><%= p.Name %></td>
              <td><%= p.Age %> / <%= p.Gender == 1 ? "M" : "F" %></td>
              <td>
                <span class="badge bg-<%= 
                    p.Status === 'waiting' ? 'secondary' :
                    p.Status === 'in_progress' ? 'warning' :
                    p.Status === 'completed' ? 'success' : 'danger'
                  %>">
                  <%= p.Status %>
                </span>
              </td>
              <td><%= p.PredictedEntryTime || '-' %></td>
              <td><%= p.PredictedExitTime || '-' %></td>
              <td><%= p.EntryTime || '-' %></td>
              <td><%= p.ExitTime || '-' %></td>
              <td>
                <% if(p.Status === 'waiting') { %>
                  <form method="post" action="/queue/mark-entry/<%= p.PatientId %>">
                    <button type="submit" class="btn btn-sm btn-primary">Mark In</button>
                  </form>
                <% } else if(p.Status === 'in_progress') { %>
                  <form method="post" action="/queue/mark-exit/<%= p.PatientId %>">
                    <button type="submit" class="btn btn-sm btn-success">Mark Out</button>
                  </form>
                <% } else { %>
                  <span class="text-muted">Done</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>

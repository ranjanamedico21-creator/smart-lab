<!-- Breadcrumb Section -->
<section class="py-4">
    <div class="container-fluid">
      <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
        <ol class="breadcrumb mb-0 d-flex align-items-center">
          <li class="breadcrumb-item">
            <a href="/user/home" class="text-decoration-none text-primary">Home</a>
          </li>
          <li class="breadcrumb-item active fw-bold" aria-current="page">
            Create Sub Test
          </li>
        </ol>
      </nav>
    </div>
  </section>
  
  <!-- Form Section -->
  <section class="pb-5">
    <div class="container-fluid">
      <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
        <div class="card-header bg-primary text-white text-center py-3">
          <h4 class="mb-0 fw-bold">
            <i class="bi bi-file-plus me-2"></i>Sub Test Details
          </h4>
        </div>
        <div class="card-body p-4">
          <%- include ("./partials/messages"); %>
  
          <% if (typeof subTestDetails != 'undefined') { %>
            <form action="/test/updateSubTest?subTestId=<%= subTestDetails[0].Id %>" method="post" class="needs-validation" novalidate>
          <% } else { %>
            <form action="/test/registerSubTest" method="post" class="needs-validation" novalidate>
          <% } %>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label for="mainCategory" class="form-label fw-bold text-dark">Category</label>
                <select class="form-control form-select" id="mainCategory" name="MainCategory" aria-label="Category Name" required>
                  <option selected disabled value="">Select Category</option>
                  <% if (typeof categories != 'undefined') { %>
                    <% categories.forEach(function(category) { %>
                      <option <% if (typeof subTestDetails != 'undefined' && subTestDetails[0].CategoryId == category.Id) { %>selected <% } %> value="<%= category.Id %>"><%= category.Name %></option>
                    <% }) %>
                  <% } %>
                </select>
                <div class="invalid-feedback">Please select a category.</div>
              </div>
              <div class="col-md-6">
                <label for="name" class="form-label fw-bold text-dark">Sub Test Name</label>
                <input
                  type="text"
                  class="form-control text-capitalize"
                  id="name"
                  name="Name"
                  placeholder="Sub Test Name"
                  value="<%= typeof subTestDetails != 'undefined' ? subTestDetails[0].Name : '' %>"
                  aria-describedby="Enter Name of Sub Test"
                  required
                />
                <div class="invalid-feedback">Please enter a sub test name.</div>
              </div>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label for="discount" class="form-label fw-bold text-dark">Discount</label>
                <input
                  type="number"
                  class="form-control"
                  name="Discount"
                  id="discount"
                  placeholder="Discount on Subtest"
                  value="<%= typeof subTestDetails != 'undefined' ? subTestDetails[0].Discount : '' %>"
                  aria-describedby="Discount on subtest"
                  required
                />
                <div class="invalid-feedback">Please enter a discount amount.</div>
              </div>
              <div class="col-md-6">
                <label for="price" class="form-label fw-bold text-dark">Price</label>
                <input
                  type="number"
                  class="form-control"
                  id="price"
                  name="Price"
                  value="<%= typeof subTestDetails != 'undefined' ? subTestDetails[0].Price : '' %>"
                  placeholder="Price"
                  aria-describedby="Enter Price of Sub Test"
                  required
                />
                <div class="invalid-feedback">Please enter a price.</div>
              </div>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label for="thanks" class="form-label fw-bold text-dark">Thanks Amount</label>
                <input
                  type="number"
                  class="form-control"
                  id="thanks"
                  name="Thanks"
                  placeholder="Thanks Amount"
                  value="<%= typeof subTestDetails != 'undefined' ? subTestDetails[0].ThanksAmount : '' %>"
                  aria-describedby="Enter Thanks Amount of Sub Test"
                  required
                />
                <div class="invalid-feedback">Please enter a thanks amount.</div>
              </div>
              <div class="col-md-6 d-flex align-items-end">
                <% if (typeof subTestDetails != 'undefined') { %>
                  <button type="submit" class="btn btn-primary w-100 py-2">Update</button>
                <% } else { %>
                  <button type="submit" class="btn btn-primary w-100 py-2">Submit</button>
                <% } %>
              </div>
            </div>
  
            <!-- Pagination Section -->
            <nav aria-label="Page navigation">
              <ul class="pagination pagination-sm justify-content-center gap-1 mt-4" id="pagination_Number">
                <li class="page-item disabled">
                  <a class="page-link rounded-pill px-3" href="#">Previous</a>
                </li>
                <!-- Dynamic pagination numbers can be added here via JS -->
                <li class="page-item">
                  <a class="page-link rounded-pill px-3" href="#">1</a>
                </li>
                <li class="page-item">
                  <a class="page-link rounded-pill px-3" href="#">Next</a>
                </li>
              </ul>
            </nav>
          </form>
        </div>
      </div>
    </div>
  </section>
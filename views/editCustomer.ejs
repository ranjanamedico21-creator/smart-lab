<!-- Breadcrumb Section -->
<section class="py-4">
    <div class="container-fluid">
      <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded-3 shadow-sm border">
        <ol class="breadcrumb mb-0 fw-medium">
          <li class="breadcrumb-item">
            <a href="/user/home" class="text-decoration-none text-primary">Home</a>
          </li>
          <li class="breadcrumb-item active text-dark" aria-current="page">Edit customer details</li>
        </ol>
      </nav>
    </div>
  </section>
  
  <!-- Customer Registration Section -->
  <section class="pb-5">
    <div class="container-fluid">
      <div class="card shadow border-0 rounded-4 bg-white overflow-hidden">
        <div class="card-header bg-gradient bg-primary text-white text-center py-3">
          <h4 class="mb-0 fw-bold">Edit customer details</h4>
        </div>
        <div class="card-body p-4">
          <form id="customerForm" action="/billing/updateCustomer/<%=customerDetails.Id %>" class="needs-validation" method="POST" novalidate>
            <!-- Customer Details -->
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label fw-semibold">Customer Name</label>
                <input type="text" name="CustomerName" class="form-control text-capitalize" value="<%=customerDetails.CustomerName %>" required>
                <div class="invalid-feedback">Customer name is required.</div>
              </div>
              <div class="col-md-2">
                <label class="form-label fw-semibold">Mobile No</label>
                <input type="text" name="MobileNo" class="form-control"  pattern="\d{10}" required value="<%=customerDetails.MobileNo %>" >
                <div class="invalid-feedback">Enter a valid 10-digit mobile number.</div>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">GST No</label>
                <input type="text" name="GstNo" class="form-control text-uppercase" pattern="^[0-9A-Z]{15}$" value="<%=customerDetails.GstNo %>" >
                <div class="invalid-feedback">Enter a valid 15-character GST No.</div>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">DL No</label>
                <input type="text" name="DlNo" class="form-control text-uppercase" pattern="^[A-Za-z0-9\-\/]+$" value="<%=customerDetails.DlNo %>" >
                <div class="invalid-feedback">Enter a valid DL number.</div>
              </div>
            </div>
  
            <!-- Billing Address Fields -->
            <h5 class="mt-4 mb-3 fw-semibold text-center">Billing Address</h5>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Billing Address</label>
                <input type="text" name="BillingAddress" class="form-control text-capitalize" required value="<%=customerDetails.BillingAddress %>" >
                <div class="invalid-feedback">Billing address is required.</div>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">State</label>
                <input type="text" name="BillingState" class="form-control text-capitalize" required value="<%=customerDetails.BillingState %>" >
                <div class="invalid-feedback">State is required.</div>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">District</label>
                <input type="text" name="BillingDistrict" class="form-control text-capitalize" required value="<%=customerDetails.BillingDistrict %>" >
                <div class="invalid-feedback">District is required.</div>
              </div>
            </div>
            <div class="row g-3 mt-3">
              <div class="col-md-3">
                <label class="form-label fw-semibold">Pincode</label>
                <input type="text" name="BillingPincode" class="form-control" pattern="\d{6}" required value="<%=customerDetails.BillingPincode %>" >
                <div class="invalid-feedback">Enter a valid 6-digit pincode.</div>
              </div>
              <div class="col-md-3 d-flex align-items-end">
                <div class="form-check">
                  <input type="checkbox" id="copyAddress" class="form-check-input">
                  <label for="copyAddress" class="form-check-label">Same as Billing</label>
                </div>
              </div>
            </div>
  
            <!-- Shipping Address Fields -->
            <h5 class="mt-4 mb-3 fw-semibold text-center">Shipping Address</h5>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Shipping Address</label>
                <input type="text" name="SupplyAddress" class="form-control text-capitalize" required value="<%=customerDetails.SupplyAddress %>" >
                <div class="invalid-feedback">Shipping address is required.</div>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">State</label>
                <input type="text" name="SupplyState" class="form-control text-capitalize" required value="<%=customerDetails.SupplyState %>">
                <div class="invalid-feedback">State is required.</div>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">District</label>
                <input type="text" name="SupplyDistrict" class="form-control text-capitalize" required value="<%=customerDetails.SupplyDistrict %>">
                <div class="invalid-feedback">District is required.</div>
              </div>
            </div>
            <div class="row g-3 mt-3">
              <div class="col-md-3">
                <label class="form-label fw-semibold">Pincode</label>
                <input type="text" name="SupplyPincode" class="form-control" pattern="\d{6}" required value="<%=customerDetails.SupplyPincode %>">
                <div class="invalid-feedback">Enter a valid 6-digit pincode.</div>
              </div>
            </div>
            <div class="d-flex gap-2 justify-content-center mt-4">
              <button type="submit" class="btn btn-success rounded-pill px-4 fw-medium">Update</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
<section>
    <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
        <li class="breadcrumb-item active text-dark" aria-current="page">Display Dues List</li>
      </ol>
    </nav>
  </section>
  <section>
    <div class="container-fluid rounded border bg-white shadow-sm mt-3">
      <div class="row text-center mt-3">
        <div class="col">
          <h4>Outstanding Dues</h4>
        </div>
      </div>
  
        <table class="table table-striped mt-3">
            <thead>
                <tr>
                    <th>Sale ID</th>
                    <th>Customer</th>
                    <th>Total Value</th>
                    <th>Total Paid</th>
                    <th>Due Amount</th>
                </tr>
            </thead>
            <tbody>
                <% dues.forEach(due => { %>
                <tr>
                    <td><%= due.SaleId %></td>
                    <td><%= due.CustomerName %></td>
                    <td>₹<%= due.TotalValue %></td>
                    <td>₹<%= due.TotalPaid %></td>
                    <td>₹<%= due.DueAmount %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</section>
<section>
        <!-- Pagination for navigation -->
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center mt-3">
              <li class="page-item disabled">
                <a class="page-link">Previous</a>
              </li>
              <ul class="pagination pagination-sm pager" id="pagination_Number"></ul>
              <li class="page-item">
                <a class="page-link" href="#">Next</a>
              </li>
            </ul>
          </nav>
</section>
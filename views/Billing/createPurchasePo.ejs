
<!-- Breadcrumb -->
<section class="py-4">
    <div class="container-fluid">
      <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
        <ol class="breadcrumb mb-0 d-flex align-items-center">
          <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none text-primary">Home</a></li>
          <li class="breadcrumb-item active fw-bold" aria-current="page"> Purchase PO – Create Manually</li>
        </ol>
      </nav>
    </div>
  </section>

  <!-- Purchase PO Form Section -->
  <section class="pb-5">
    <div class="container-fluid">
      <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
        <div class="card-header bg-primary text-white text-center py-3">
          <h4 class="mb-0 fw-bold"><i class="bi bi-cart-plus me-2"></i>Purchase PO</h4>
        </div>
        
        <div class="card-body p-4">
          <%- include ("../partials/messages"); %>

          <form action="/billing/createPurchasePo" class="needs-validation" novalidate method="POST">
            <!-- Supplier Selection -->
            <div class="row g-3 mb-4">
              <div class="col-md-6">
                <label for="supplierIdPurchasePo" class="form-label fw-bold">Supplier</label>
                <select name="supplierId" id="supplierIdPurchasePo" class="form-control" required>
                  <option value="" disabled selected>Select a supplier</option>
                  <% suppliers.forEach(supplier => { %>
                    <option value="<%= supplier.Id %>"><%= supplier.Name %></option>
                  <% }); %>
                </select>
                <div class="invalid-feedback">Please select a supplier.</div>
              </div>
              <div class="col-md-4">
                <label for="purchasePoDate" class="form-label fw-semibold">Po Date <span class="text-danger">*</span></label>
                <input type="text" id="purchasePoDate" name="purchasePoDate" class="form-control"
                  placeholder="e.g., 03-03-2025"
                  value="<%= typeof purchasePoDate !== 'undefined' ? purchasePoDate : '' %>"
                  autocomplete="off" required>
                <div class="invalid-feedback">Purchase Po date is required.</div>
              </div>
            </div>

            <!-- Product List Section -->
            <div id="productList" class="mb-4">
              <div class="product-item row g-3 mb-3">
                <div class="col-md-3">
                  <label class="form-label fw-bold">Product</label>
                  <select name="productId[]" class="form-control ppProduct"data-live-search="true" required>
                    <option value="" disabled selected>Select a product</option>
                    <% products.forEach(product => { %>
                      <option data-supplier-id="<%= product.SupplierId %>" value="<%= product.Id %>"><%= product.ProductName %></option>
                    <% }); %>
                  </select>
                  <div class="invalid-feedback">Please select a product.</div>
                </div>
                <div class="col-md-2">
                  <label class="form-label fw-bold">Quantity</label>
                  <input type="number" name="quantity[]" class="form-control" min="1" required>
                  <div class="invalid-feedback">Quantity is required.</div>
                </div>
                <div class="col-md-2">
                  <label class="form-label fw-bold">MRP</label>
                  <input type="number" name="mrp[]" class="form-control" step="0.01" required>
                  <div class="invalid-feedback">MRP is required.</div>
                </div>
                <div class="col-md-2">
                  <label class="form-label fw-bold">Purchase Price</label>
                  <input type="number" name="purchasePrice[]" class="form-control" step="0.01" required>
                  <div class="invalid-feedback">Price is required.</div>
                </div>
                <div class="col-md-2">
                  <label class="form-label fw-bold">IGST (%)</label>
                  <input type="number" name="igst[]" class="form-control" step="0.01" required>
                  <div class="invalid-feedback">IGST is required.</div>
                </div>
                <div class="col-md-1 d-flex align-items-end justify-content-center">
                  <!--button type="button" class="btn btn-danger removeProduct"><i class="bi bi-trash"></i></button-->
                </div>
              </div>
            </div>

            <!-- Add More Button -->
            <div class="row mb-4">
              <div class="col text-center">
                <button type="button" id="addProduct" class="btn btn-success"><i class="bi bi-plus-circle me-2"></i>Add More</button>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="row">
              <div class="col text-center">
                <button type="submit" class="btn btn-primary px-5">Submit Purchase PO</button>
              </div>
            </div>
            <input type="hidden" name="supplierId" id="supplier">
          </form>
        </div>
      </div>
        <!-- OR separator -->
    <div class="text-center my-3">
      <span class="fw-bold text-muted">— OR —</span>
    </div>

    <!-- Option 2: Upload Purchase PO PDF -->

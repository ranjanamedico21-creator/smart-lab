  </section>
<script>
document.addEventListener("DOMContentLoaded", function () {
    const supplierDropdown = document.getElementById("supplierIdPurchasePo");
    const productList = document.getElementById("productList");
    const addProductButton = document.getElementById("addProduct");
    
    const products = <%- JSON.stringify(products) %>; // Corrected way to pass products array

    // Lock supplier selection after the first selection
    supplierDropdown.addEventListener("change", function () {
        supplierDropdown.disabled = true;
        const supplierId= document.getElementById('supplierIdPurchasePo').value 
        document.getElementById('supplier').value= supplierId 
        //after changing the supplier only that supplier product is visible
        $(".ppProduct > option").each(function () {
            let attachedSupplierId = parseInt($(this).attr("data-supplier-id"));
            $("select").selectpicker("destroy");
            // make discount vield emptys
            if (attachedSupplierId != supplierId) 
                $(this).hide();  
             else 
                $(this).show();
                
                $('select').selectpicker({
                    dropupAuto: false,
                    container: 'body' // Append dropdown to body
                  });
        });


    });

    // Function to add a new product row
    function addProductRow() {

       // alert('hi')
        const productList = document.getElementById("productList");

let newProductRow = document.createElement("div");
newProductRow.innerHTML = `
    <div class="product-item row g-3 mb-3">
        <div class="col-md-3">
            <label class="form-label fw-bold">Product</label>
            <select name="productId[]" class="form-control ppProduct" data-live-search="true" required>
                <option value="" disabled selected>Select a product</option>
                <% products.forEach(product => { %>
                    <option data-supplier-id="<%= product.SupplierId %>" value="<%= product.Id %>"><%= product.ProductName %></option>
                <% }); %>
            </select>
            <div class="invalid-feedback">Please select a product.</div>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-bold">Quantity</label>
            <input type="number" name="quantity[]" class="form-control" min="1" required>
            <div class="invalid-feedback">Quantity is required.</div>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-bold">MRP</label>
            <input type="number" name="mrp[]" class="form-control" step="0.01" required>
            <div class="invalid-feedback">MRP is required.</div>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-bold">Purchase Price</label>
            <input type="number" name="purchasePrice[]" class="form-control" step="0.01" required>
            <div class="invalid-feedback">Price is required.</div>
        </div>
        <div class="col-md-2">
            <label class="form-label fw-bold">IGST (%)</label>
            <input type="number" name="igst[]" class="form-control" step="0.01" required>
            <div class="invalid-feedback">IGST is required.</div>
        </div>
        <div class="col-md-1 d-flex align-items-end justify-content-center">
            <button type="button" class="btn btn-danger removeProduct"><i class="bi bi-trash"></i></button>
        </div>
    </div>
`;

// Append the first child inside newProductRow (actual element)
productList.appendChild(newProductRow.firstElementChild);
applySelectPicker();

        newProductRow.querySelectorAll(".form-control").forEach(input => {
        input.classList.remove("is-invalid");
    });
        $(".ppProduct > option").each(function () {
            let attachedSupplierId = parseInt($(this).attr("data-supplier-id"));
            const supplierId= document.getElementById('supplierIdPurchasePo').value 
            $("select").selectpicker("destroy");
            // make discount vield emptys
            if (attachedSupplierId != supplierId) 
                $(this).hide();  
             else 
                $(this).show();
                
               
        });
        applySelectPicker(); // Reapply select picker
    }

    // Apply Bootstrap select picker
    function applySelectPicker() {
        $('select').selectpicker({
                    dropupAuto: false,
                    container: 'body' // Append dropdown to body
                  });
    }

    // Event listener for adding products
    addProductButton.addEventListener("click", function () {
        addProductRow();
    });

    // Event listener for removing products
    productList.addEventListener("click", function (event) {
        if (event.target.closest(".removeProduct")) {
            event.target.closest(".product-item").remove();

            // If no products left, enable supplier dropdown again
            if (productList.children.length === 0) {
                supplierDropdown.disabled = false;
            }
        }
    });

    applySelectPicker(); // Initial call for existing select pickers
});

</script>



<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Patient List
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Search and List Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-person-lines-fill me-2"></i>Patient List
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include ("./partials/messages"); %>

        <!-- Search Form -->
        <form action="/patient/searchPatient" method="post" class="mb-4">
          <!-- Row 1: Bill No and Patient Name -->
          <div class="row g-3">
            <div class="col-md-6">
              <input
                type="number"
                class="form-control"
                id="billNo"
                name="BillNo"
                placeholder="Bill No"
                value="<%= typeof BillNo!= 'undefined' ? BillNo : '' %>"
              />
            </div>
            <div class="col-md-6">
              <input
                type="text"
                class="form-control"
                id="name"
                name="Name"
                placeholder="Enter Patient Name"
                value="<%= typeof Name!= 'undefined' ? Name : '' %>"
              />
            </div>
          </div>

          <!-- Row 2: From Date and To Date -->
          <div class="row g-3 mt-3">
            <div class="col-md-6">
              <input
                type="text"
                id="FromDate"
                class="form-control"
                name="FromDate"
                placeholder="From Date"
                value="<%= typeof FromDate!= 'undefined' ? FromDate : '' %>"
                autocomplete="off"
              />
            </div>
            <div class="col-md-6">
              <input
                type="text"
                class="form-control"
                id="ToDate"
                name="ToDate"
                placeholder="To Date"
                value="<%= typeof ToDate!= 'undefined' ? ToDate : '' %>"
                autocomplete="off"
              />
            </div>
          </div>

          <!-- Row 3: Doctor and Status -->
          <div class="row g-3 mt-3">
            <div class="col-md-4">
              <select
                name="Doctor"
                class="form-control text-capitalize"
                id="doctor"
                data-live-search="true"
                aria-label="Select doctor with live search"
              >
                <option value="" selected>Select a Doctor</option>
                <%doctorDetails.forEach(function(doctor){ %>
                  <option
                    value="<%=doctor.Id%>"
                    <% if(typeof doctorId != 'undefined' && doctor.Id == doctorId){%>selected<%}%>
                  >
                    <%=doctor.FirstName%> <%=doctor.LastName%>
                  </option>
                <%})%>
              </select>
            </div>
            <div class="col-md-4">
              <select name="Status" id="status" aria-label="Status" class="form-control">
                <option value="" selected>Status</option>
                <option <% if(typeof Status != 'undefined' && Status == '1'){%>selected<%}%> value="1">
                  Active
                </option>
                <option <% if(typeof Status != 'undefined' && Status == '2'){%>selected<%}%> value="2">
                  Cancelled
                </option>
              </select>
            </div>
            <div class="col-md-4">
              <select class="form-control rounded-3" id="mainCategory" name="MainCategory" aria-label="Category Name">
                  <option selected disabled value="">Select Category</option>
                  <% if (typeof categories != 'undefined') { %>
                      <% categories.forEach(function(category) { %>
                        <option value="<%= category.Id %>" <% if(typeof categoryId != 'undefined' && categoryId == category.Id){%>selected<%}%>  id="<%= category.Name %>">
                          <%= category.Name %>
                        </option>
                      <% }) %>
                  <% } %>
              </select>
          </div>
          </div>

          <!-- Row 4: Buttons -->
          <div class="row g-3 mt-3">
            <div class="col-md-6">
              <a class="btn btn-primary w-100 py-2" href="/patient/registerPatient" role="button">
                Register Patient
              </a>
            </div>
            <div class="col-md-6">
              <button class="btn btn-primary w-100 py-2" type="submit">Search</button>
            </div>
          </div>
        </form>

        <!-- Patient List Table -->
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">
            <thead class="table-primary">
              <tr>
                <th scope="col">#</th>
                <th scope="col">Patient Detail</th>
                <th scope="col">Referred By</th>
                <th scope="col">Gross Amount</th>
                <th scope="col">Date</th>
                <th scope="col">Status</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody class="pagination-loop">
              <% let i=1; patientDetails.forEach(function(patient){ %>
                <tr
                  class="<% if (patient.DuesAmount > 0 && patient.Status == 1) { %>table-danger<% } %> <% if (patient.Status == 2) { %>text-decoration-line-through text-muted<% } %>"
                >
                  <td><%=i%>.</td>
                  <td class="text-capitalize">
                    <p class="mb-1">
                      <a data-bs-toggle="tooltip" data-bs-custom-class="custom-tooltip" data-bs-placement="top"
                        title="<%= patient.TestNames %>" 
                         href="/patient/getPatientDetail?patientId=<%= patient.PatientId %>"
                        class="link-primary fw-semibold text-decoration-none">
                        <%= patient.Title %> <%= patient.Name %>
                      </a>
                    </p>
                    <p class="text-muted mb-1">
                      <% if(patient.Gender == 1) { %>
                        <i class="bi bi-gender-male text-info"></i> Male
                      <% } else { %>
                        <i class="bi bi-gender-female text-danger"></i> Female
                      <% } %>
                      | <%= patient.Age %> <%= patient.YMD %>
                    </p>
                    <p class="mb-0">
                      <i class="bi bi-phone text-success" style="font-size: 1rem;"></i>
                      <span class="fw-medium">+91 <%= patient.PhoneNumber %></span>
                    </p>
                  </td>
                  <td
                    class="text-capitalize"
                    data-bs-toggle="tooltip"
                    data-bs-custom-class="custom-tooltip"
                    data-bs-placement="top"
                    title="<%=patient.DoctorDegree1%>,<%=patient.DoctorDegree2%>"
                  >
                    <strong class="text-teal">Dr. <%= patient.DoctorFirstName%> <%= patient.DoctorLastName %></strong>
                    <br />
                    <small class="text-muted">
                      <i class="bi bi-clipboard-heart"></i> <%= patient.DoctorSpecialistIn %>
                    </small>
                  </td>
                  <td class="fw-bold fs-7">₹ <%= patient.GrossAmount %></td>
                  <td class="text-muted fs-7">
                    <i class="bi bi-calendar-event"></i> <%= patient.RegisteredOn %>
                  </td>
                  <td
                    class="<% if(patient.Status == 1) { %>text-success<% } else if(patient.Status == 2) { %>text-danger<% } %>"
                  >
                    <% if(patient.Status == 1) { %> Active <% } else { %> Cancelled <% } %>
                  </td>
                  <td>
                    <a
                      href="/patient/invoices/?id=<%=patient.PatientId %>"
                      class="text-primary text-decoration-none me-2"
                      target="_blank"
                    >
                      <i class="bi bi-printer"></i>
                    </a>
                    <a
                      href="/patient/editPatientDetails?id=<%=patient.PatientId%>"
                      class="text-primary text-decoration-none me-2"
                    >
                      <i class="bi bi-pencil-square"></i>
                    </a>
                    <% if(typeof patient.Status != 'undefined' && patient.Status == '1'){%>
                      <a
                        href="/patient/deletePatientDetail?id=<%=patient.PatientId%>"
                        class="text-danger text-decoration-none me-2"
                        data-bs-toggle="modal"
                        data-bs-target="#cancelPatient"
                        data-bs-patient-name="<%=patient.Title%> <%=patient.Name%>"
                        data-bs-patient-id="<%=patient.PatientId%>"
                      >
                        <i class="bi bi-trash"></i>
                      </a>
                    <%}%>
                    <a
                      href="https://wa.me/+91<%=patient.PhoneNumber%>"
                      class="text-success text-decoration-none"
                    >
                      <i class="bi bi-whatsapp"></i>
                    </a>
                  </td>
                </tr>
              <% i++; })%>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <nav aria-label="Page navigation">
          <div class="container">
            <div class="d-flex justify-content-center">
              <div class="w-100 overflow-auto">
                <ul class="pagination pagination-sm gap-1 mt-4 flex-nowrap justify-content-center overflow-auto" id="pagination_Number" style="white-space: nowrap; scroll-behavior: smooth;">
                  <li class="page-item disabled">
                    <a class="page-link rounded-pill px-3 prev_link" href="#">Previous</a>
                  </li>
                  <!-- Page numbers will be inserted here via JavaScript -->
                  <li class="page-item">
                    <a class="page-link rounded-pill px-3 next_link" href="#">Next</a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </nav>
        
             
      </div>
    </div>
  </div>
</section>


<div
  class="modal fade"
  id="cancelPatient"
  data-bs-backdrop="static"
  data-bs-keyboard="false"
  tabindex="-1"
  aria-labelledby="cancelPatientLabel"
  aria-hidden="true"
>
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-light border-0">
        <h1 class="modal-title fs-4 fw-bold text-dark text-capitalize" id="cancelPatientLabel">
          Cancel Patient
        </h1>
        <button
          type="button"
          class="btn-close btn-close-dark"
          data-bs-dismiss="modal"
          aria-label="Close"
        ></button>
      </div>
      
      <div class="modal-body p-4">
        <form
          action="/patient/cancelPatient"
          method="post"
          id="cancelPatientForm"
          class="needs-validation"
          novalidate
        >
          <div class="mb-4">
            <label for="message-text" class="form-label fw-medium text-muted">
              Reason for Cancellation
              <span class="text-danger">*</span>
            </label>
            <textarea
              class="form-control form-control-lg shadow-sm"
              name="reason"
              id="message-text"
              rows="4"
              placeholder="Enter cancellation reason..."
              required
            ></textarea>
            <div class="invalid-feedback mt-1">
              Please provide a reason for cancellation.
            </div>
          </div>

          <!-- Hidden Inputs -->
          <input type="hidden" class="modal-cancel-patient-id" name="cancelPatientId" />
          <input type="hidden" class="modal-searched-patient-bill-no" id="searchedBillNo" value="<%= typeof BillNo!= 'undefined' ? BillNo : '' %>" name="BillNo" />
          <input type="hidden" class="modal-searched-patient-name" id="searchedName"  value="<%= typeof Name!= 'undefined' ? Name : '' %>" name="Name" />
          <input type="hidden" class="modal-searched-patient-from-date" id="searchedFromDate"  value="<%= typeof FromDate!= 'undefined' ? FromDate : '' %>" name="FromDate" />
          <input type="hidden" class="modal-searched-patient-to-Date" id="searchedToDate" value="<%= typeof ToDate!= 'undefined' ? ToDate : '' %>" name="ToDate" />
          <input type="hidden" class="modal-searched-patient-doctor" id="searchedDoctor" value="<%= typeof doctorId!= 'undefined' ? doctorId : '' %>" name="Doctor" />
          <input type="hidden" class="modal-searched-patient-status" id="searchedStatus" value="<%= typeof Status!= 'undefined' ? Status : '' %>" name="Status" />

          <div class="d-flex justify-content-end gap-2">
            <button
              type="button"
              class="btn btn-outline-secondary btn-lg px-4"
              data-bs-dismiss="modal"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="btn btn-primary btn-lg px-4 shadow-sm"
              form="cancelPatientForm"
            >
              Confirm
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<!-- Breadcrumb -->
<section class="py-3 bg-light border-bottom">
  <div class="container-fluid">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary fw-semibold">
            <i class="bi bi-house-door-fill me-1"></i>Home
          </a>
        </li>
        <li class="breadcrumb-item active fw-semibold text-dark" aria-current="page">
          Stock Details
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Stock Details Table -->
<section class="py-4">
  <div class="container-fluid">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-header bg-white border-0 py-3 d-flex align-items-center justify-content-between">
        <h4 class="mb-0 fw-semibold text-primary">
          <i class="bi bi-box-seam me-2"></i>Stock Details
        </h4>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-center">
              <tr>
                <th>#</th>
                <th>Product Name</th>
                <th>Batch No.</th>
                <th>MRP (₹)</th>
                <th>Purchase Price (₹)</th>
                <th>Quantity</th>
                <th>Expiry</th>
                <th>Created At</th>
              </tr>
            </thead>
            <tbody>
              <% let i = 0; stockDetails.forEach(stock => { i++; %>
              <tr>
                <td class="text-center fw-semibold"><%= i %></td>
                <td>
                  <a href="/billing/stockHistory/<%=stock.stockId%>/<%=stock.BatchNumber%>" 
                     class="text-decoration-none fw-semibold text-dark hover-link">
                    <%= stock.ProductName %>
                  </a>
                </td>
                <td class="text-center text-muted"><%= stock.BatchNumber %></td>
                <td class="text-center"><%= stock.MRP %></td>
                <td class="text-center"><%= stock.PurchasePrice %></td>
                <td class="text-end fw-semibold"><%= stock.Quantity %></td>
                <td class="text-center">
                  <span class="badge bg-light text-dark border">
                    <%= new Date(stock.ExpiryDate).toLocaleDateString('en-GB', {
                      day: '2-digit', month: '2-digit', year: 'numeric'
                    }).replace(/\//g, '-') %>
                  </span>
                </td>
                <td class="text-center text-muted small">
                  <%= new Date(stock.CreatedAt).toLocaleDateString('en-GB', {
                    day: '2-digit', month: '2-digit', year: 'numeric'
                  }).replace(/\//g, '-') %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pagination -->
<section class="py-3">
  <nav aria-label="Page navigation">
    <div class="container-fluid d-flex justify-content-center">
      <ul class="pagination pagination-sm mt-3 gap-2">
        <li class="page-item disabled">
          <a class="page-link rounded-pill px-3 prev_link shadow-sm" href="#">Previous</a>
        </li>
        <!-- Page numbers inserted via JS -->
        <li class="page-item">
          <a class="page-link rounded-pill px-3 next_link shadow-sm" href="#">Next</a>
        </li>
      </ul>
    </div>
  </nav>
</section>


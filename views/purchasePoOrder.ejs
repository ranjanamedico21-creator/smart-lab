
<section>
    <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
        <li class="breadcrumb-item active text-dark" aria-current="page">Receive Purchase Po Order</li>
      </ol>
    </nav>
  </section>
  <section>
    <div class="container-fluid rounded border bg-white shadow-sm mt-3">
        <div class="row text-center mt-3">
            <div class="col">
                <h4>Receive Purchase Order & Generate Invoice</h4>
            </div>
        </div>
        <%- include ("./partials/messages"); %>
        <!-- Invoice Header -->
        <div class="row mb-4">
            <div class="col-7 text-center">
                <h4 class="fw-bold"><%= companyDetails.coreCompany %></h4>
                <p class="text-muted"><%= companyDetails.coreCompanyAddress %></p>
                <p class="text-muted">Email: <%= companyDetails.coreCompanyEmail %> | Phone: <%= companyDetails.coreCompanyPhoneNumber %></p>
            </div>
            <div class="col-3 text-end">
                <img src="logo-placeholder.png" alt="Company Logodd" class="img-fluid" style="max-height: 80px;">
            </div>
            <div class="col-2">
                    <a href="/billing/downloadPurchasePo/<%= purchaseOrderId %>/<%=supplierDetails[0].Id %>" class="btn btn-primary btn-sm" id="downloadPdf">Download as PDF</a>
            </div>
        </div>
    <hr class="border-dark">

        <!-- Invoice Information -->
        <div class="row text-center py-3 bg-secondary text-white">
            <div class="col">
                <h6>GSTIN: <%= companyDetails.coreCompanyGstNo %> </h6>
            </div>
            <div class="col">
                <h6 class="fw-bold">TAX INVOICE</h6>
            </div>
            <div class="col">
                <h6>Original for Recipient</h6>
            </div>
        </div>

    <!-- Supplier and Purchase Po Details -->
    <div class="row my-4">
        <div class="col-md-6 border-end">
            <h6 class="text-center text-uppercase text-decoration-underline">Party Details</h6>
            <p class="text-capitalize">
                <strong>Name:</strong> <%=supplierDetails[0].Name %><br>
                <strong>Address:</strong>  <%=supplierDetails[0].Address %><br>
                <strong>Phone:</strong>  <%=supplierDetails[0].ContactNo %><br>
                <strong>GSTIN:</strong>  <%=supplierDetails[0].GstIn %><br>
               <!--<strong>Place of Supply:</strong> <%=supplierDetails[0].PlaceOfSupply %>-->
            </p>
        </div>
        <div class="col-md-6">
            <h6 class="text-center text-uppercase text-decoration-underline">Invoice Details</h6>
            <p>
                <strong>Invoice No.:</strong> <%= totalPurchasePoAmount[0].PurchaseInvoiceNo %><br>
                <strong>Invoice Date:</strong> <%=totalPurchasePoAmount[0].OrderDate %><br>
                <strong>Challan No.:</strong> <br>
                <strong>Delivery Date:</strong> <br>
            </p>
        </div>
    </div>
    <br>
    <!-- Invoice Items Table -->
    <div class="row mt-4">
        <div class="col">
            <table class="table table-bordered table-hover">
                <thead class="table-secondary">
                    <tr>
                        <th>Sr. No.</th>
                        <th>Name of Product / Service</th>
                        <th>Qty</th>
                        <th>Rate</th>
                        <th>Taxable Value</th>
                        <th>IGST (%)</th>
                        <th>IGST Amount</th>
                        <th>Total With Tax</th>
                    </tr>
                </thead>
                <tbody>
                  <% i=1;totalPurchaseDetails.forEach(function(purchase){ %>
                    <tr>
                        <td><%=i++%>.</td>
                        <td><%= purchase.ProductName%></td>
                        <td><%= purchase.Quantity %></td>
                        <td><%=purchase.PurchasePrice %></td>
                        <td><%= purchase.TotalAmount%></td>
                        <td><%= purchase.IGSTPercentage%></td>
                        <td><%= purchase.IGSTAmount%></td>
                        <td><%= Number(purchase.TotalAmount) + Number(purchase.IGSTAmount) %></td>
                    </tr>
                    <%})%>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Bank and Summary Details -->
    <div class="row mt-4">
        <div class="col-md-6 border-end">
            <h6 class="text-center text-uppercase text-decoration-underline">Bank Details</h6>
            <p>
                <strong>Bank Name:</strong> <%= companyDetails.coreCompanyBankName %><br>
                <strong>Branch Name:</strong> <%= companyDetails.coreCompanyBranchName %><br>
                <strong>Bank Account Number:</strong> <%= companyDetails.coreCompanyAccountNo %><br>
                <strong>IFSC Code:</strong>  <%= companyDetails.coreCompanyIFSCCode %><br>
            </p>
        </div>
        <div class="col-md-6">
            <h6 class="text-center text-uppercase text-decoration-underline">Summary</h6>
            <p>
                <strong>Taxable Amount:</strong> <%= totalPurchasePoAmount[0].TotalValue %><br>
                <strong>Add IGST:</strong><%= totalPurchasePoAmount[0].IgstAmount %><br>
                <strong>Total Amount After Tax:</strong><%= Number(totalPurchasePoAmount[0].IgstAmount) + Number(totalPurchasePoAmount[0].TotalValue) %><br>
            </p>
        </div>
    </div>

    <!-- Terms and Conditions -->
    <div class="row mt-4">
        <div class="col-md-6 border-end">
            <h6 class="text-uppercase text-decoration-underline">Terms and Conditions</h6>
            <ul class="list-unstyled">
                <li>1. Subject to Patna Jurisdiction.</li>
                <li>2. Our responsibility ceases as soon as the goods leave our premises.</li>
                <li>3. Goods once sold will not be taken back.</li>
                <li>4. Delivery ex-premises.</li>
            </ul>
        </div>
        <div class="col-md-6 text-center">
            <h6 class="text-uppercase">Authorized Signatory</h6>
            <p>(Place for signature)</p>
        </div>
    </div>
</div>

<section>
    <!-- Pagination for navigation -->
    <nav aria-label="Page navigation">
      <ul class="pagination pagination-sm justify-content-center mt-3">
        <li class="page-item disabled">
          <a class="page-link">Previous</a>
        </li>
        <ul class="pagination pagination-sm pager" id="pagination_Number"></ul>
        <li class="page-item">
          <a class="page-link" href="#">Next</a>
        </li>
      </ul>
    </nav>
</section>
  

<!-- Breadcrumb -->
<section class="py-4 bg-light">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="bg-white border rounded-4 px-4 py-3 shadow-sm">
      <ol class="breadcrumb mb-0 fw-semibold text-secondary">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary d-flex align-items-center">
            <i class="bi bi-house-door-fill me-1"></i> Home
          </a>
        </li>
        <li class="breadcrumb-item active text-dark" aria-current="page">
          Supplier List
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Supplier List Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
      <div class="card-header bg-gradient bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-truck me-2"></i>Supplier List
        </h4>
      </div>

      <div class="card-body p-4 bg-light">
        <%- include ("./partials/messages"); %>

        <!-- Supplier Table -->
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-primary text-dark">
              <tr>
                <th scope="col" class="text-center" style="width: 50px;">#</th>
                <th scope="col">Name</th>
                <th scope="col">Address</th>
                <th scope="col">Mobile</th>
                <th scope="col">GST Number</th>
                <th scope="col">Created Date</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              <% let i = 0; suppliers.forEach(function(supplier) { i++; %>
                <tr class="table-row align-middle">
                  <td class="text-center fw-semibold"><%= i %>.</td>
                  <td>
                    <a href="/billing/supplierLedger/<%= supplier.Id %>" 
                       class="text-decoration-none text-dark fw-semibold hover-link">
                      <%= supplier.Name %>
                    </a>
                  </td>
                  <td><%= supplier.Address %></td>
                  <td><%= supplier.ContactNo %></td>
                  <td><%= supplier.GstIn || 'N/A' %></td>
                  <td>
                    <span class="fw-medium">
                      <%= new Date(supplier.CreatedAt).toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: 'numeric' }).replace(/\//g, '-') %>
                    </span><br>
                    <small class="text-muted">
                      <%= new Date(supplier.CreatedAt).toLocaleTimeString('en-GB', {
                        hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false
                      }) %>
                    </small>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Pagination -->
<section class="pt-4 pb-5">
  <div class="container-fluid">
    <nav aria-label="Page navigation">
      <ul class="pagination justify-content-center flex-wrap gap-2 mt-3" id="pagination_Number">
        <li class="page-item disabled">
          <a class="page-link rounded-pill px-4 shadow-sm prev_link" href="#">Previous</a>
        </li>
        <!-- Page numbers inserted via JS -->
        <li class="page-item">
          <a class="page-link rounded-pill px-4 shadow-sm next_link" href="#">Next</a>
        </li>
      </ul>
    </nav>
  </div>
</section>
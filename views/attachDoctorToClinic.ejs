<section>
  <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item active text-dark" aria-current="page">Attach Doctor</li>
    </ol>
  </nav>
</section>

  <!-- Clinic Details -->
  <div class="container-fluid rounded border bg-white shadow-sm">
    <div class="row mt-3 text-center">
      <div class="col">
        <h4>Clinic Details</h4>
      </div>
    </div>
    <%- include ("./partials/messages"); %>
    <table class="table table-hover table-bordered">
      <thead class="table-primary">
        <tr>
          <th>#</th>
          <th>Clinic Name</th>
          <th>Email</th>
          <th>Phone Number</th>
          <th>Address</th>
          <th>Key Area</th>
          <th>Landmark</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <th scope="row">1.</th>
          <td class="text-capitalize" ><%= clinicDetails.Name %></td>
          <td><%= clinicDetails.Email %></td>
          <td><%= clinicDetails.PhoneNumber %></td>
          <td class="text-capitalize text-truncate" style="max-width: 180px;" 
              data-bs-toggle="tooltip" data-bs-custom-class="custom-tooltip" data-bs-placement="top" title="<%= clinicDetails.Address %>">
              <%= clinicDetails.Address %>
          </td>
          <td class="text-capitalize" ><%= clinicDetails.KeyArea %></td>
          <td class="text-capitalize" ><%= clinicDetails.LandMark %></td>
        </tr>
      </tbody>
    </table>

    <% if(attachedDoctorList) { %>
    <h4 class="mt-4">Attached Doctors</h4>
    <table class="table table-hover table-bordered">
      <thead class="table-success">
        <tr>
          <th>#</th>
          <th>Doctor Name</th>
          <th>Degree</th>
          <th>Specialist In</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% i=1; attachedDoctorList.forEach(function(doctor) { %>
          <tr>
            <th scope="row"><%= i %>.</th>
            <td class="text-capitalize" ><%= doctor.FirstName %> <%= doctor.LastName %></td>
            <td class="text-capitalize text-truncate" style="max-width: 180px;" 
            data-bs-toggle="tooltip" data-bs-custom-class="custom-tooltip" data-bs-placement="top" title="<%= doctor.Degree1 %> <%= doctor.Degree2 %> <%= doctor.Degree3 %> <%= doctor.Degree4 %>">
              <%= doctor.Degree1 %> <%= doctor.Degree2 %> <%= doctor.Degree3 %> <%= doctor.Degree4 %>
        </td>
            <td  class="text-capitalize"><%= doctor.SpecialistIn %></td>
            <td>
              <a href="/clinic/detachDoctor/<%= doctor.Id %>/<%= clinicDetails.Id %>" class="btn btn-sm btn-danger">Remove</a>
            </td>
          </tr>
        <% i++; }) %>
      </tbody>
    </table>
    <% } %>
  </div>

    <!-- Register Doctor with Clinic -->
    <h4 class="mt-4">Register Doctor With Clinic</h4>
    <section class="mt-3">
      <div class="container rounded border bg-white p-4 shadow-sm">
        <form action="/clinic/attachDoctorToClinic?clinicId=<%= clinicDetails.Id %>" id="attachDoctorToClinic" method="post">
          <!-- Search Box -->
          <div class="input-group mb-3">
            <input type="text" class="form-control tableSearch" placeholder="Search doctor..." aria-label="Search doctor">
            <button class="btn btn-outline-secondary" type="button">🔍</button>
          </div>

          <!-- Available Doctors Table -->
          <table class="table table-hover table-bordered">
            <thead class="table-warning">
              <tr>
                <th>#</th>
                <th>Doctor Name</th>
                <th>Degree</th>
                <th>Specialist In</th>
                <th>Worked At</th>
                <th>Select</th>
              </tr>
            </thead>
            <tbody class="pagination-loop tableBody">
              <% i=1; unAttachedDoctorList.forEach(function(doctor) { %>
              <tr>
                <th scope="row"><%= i %>.</th>
                <td class="text-capitalize" ><%= doctor.FirstName %> <%= doctor.LastName %></td>
                <td class="text-capitalize text-truncate" style="max-width: 180px;" 
                    data-bs-toggle="tooltip" data-bs-custom-class="custom-tooltip" data-bs-placement="top" title="<%= doctor.Degree1 %> <%= doctor.Degree2 %> <%= doctor.Degree3 %> <%= doctor.Degree4 %>">
                      <%= doctor.Degree1 %> <%= doctor.Degree2 %> <%= doctor.Degree3 %> <%= doctor.Degree4 %>
                </td>
                <td class="text-capitalize"><%= doctor.SpecialistIn %></td>
                <td class="text-capitalize" ><%= doctor.WorkedAt %></td>
                <td>
                  <div class="form-check">
                    <input class="form-check-input attachDoctor" type="checkbox" value="<%= doctor.Id %>" name="doctor" id="doctor<%= doctor.Id %>">
                    <label class="form-check-label" for="doctor<%= doctor.Id %>"></label>
                  </div>
                </td>
              </tr>
              <% i++; }) %>
            </tbody>
          </table>
          <!-- Submit Button -->
          <button type="submit" class="btn btn-primary mt-3">Attach Doctor</button>
        </form>
         <!-- Pagination for navigation -->
      </div>
    </section>

     <!-- Pagination Section -->
  <section class="pb-4 mt-3">
    <nav aria-label="Page navigation">
      <div class="container">
        <div class="d-flex justify-content-center">
          <div class="w-100 overflow-auto">
            <ul class="pagination pagination-sm gap-1 mt-4 flex-nowrap justify-content-center overflow-auto" id="pagination_Number" style="white-space: nowrap; scroll-behavior: smooth;">
              <li class="page-item disabled">
                <a class="page-link rounded-pill px-3 prev_link" href="#">Previous</a>
              </li>
              <!-- Page numbers will be inserted here via JavaScript -->
              <li class="page-item">
                <a class="page-link rounded-pill px-3 next_link" href="#">Next</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </nav>
  </section>

  <!-- Pagination -->
 
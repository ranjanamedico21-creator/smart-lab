<section>
    <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
        <li class="breadcrumb-item active text-dark" aria-current="page">Customer Ledger</li>
      </ol>
    </nav>
  </section>
  <section>
    <div class="container rounded border bg-white shadow-sm mt-3">
        <div class="row mt-3 text-center">
            <div class="col">
                <h4>Customer Ledger</h4>
            </div>
        </div>
        <form action="/billing/customerLedger/<%= customerDetails.Id %>" method="post">
            <div class="row">
                <!-- Financial Year Selection -->
                <div class="col mb-3">
                    <select id="financialYear" data-selected="<%= typeof financialYear!= 'undefined' ? financialYear : '' %>" name="financialYear" class="form-control">
                        <!-- Options will be dynamically added -->
                    </select>
                </div>
                 <!-- Quick Filters -->
                 <div class="col">
                    <button type="button" class="btn btn-outline-secondary quick-filter" data-filter="currentFY">Current FY</button>
                    <button type="button" class="btn btn-outline-secondary quick-filter" data-filter="lastFY">Last FY</button>
                    <button type="button" class="btn btn-outline-secondary quick-filter" data-filter="last3Months">Last 3 Months</button>
                </div>
            </div>
            
        
                <!-- Date Range Selection -->
                <div class="row mb-3">
                    <div class="col-md-5">
                        <label for="FromDate" class="form-label">From Date</label>
                        <input type="text" data-start="<%= typeof startDate!= 'undefined' ? startDate : '' %>" name="startDate" id="FromDate" class="form-control datepicker" value="<%= typeof startDate!= 'undefined' ? startDate : '' %>" autocomplete="off" placeholder="Select start date">
                    </div>
                    <div class="col-md-5">
                        <label for="ToDate" class="form-label">To Date</label>
                        <input type="text" data-end="<%= typeof endDate!= 'undefined' ? endDate : '' %>" name="endDate" id="ToDate" class="form-control datepicker" value="<%= typeof endDate!= 'undefined' ? endDate : '' %>" autocomplete="off" placeholder="Select end date">
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button  type="submit" class="btn btn-primary w-100">Apply</button>
                    </div>
                </div>
        </form>
    </div>
   
</section>

<section>
    <div class="container bg-white border rounded p-4">
        <h1 class="text-center mb-3">Customer Ledger</h1>
        <% if (customerDetails) { %>
            <div class="row mb-3">
                <div class="col-9">
                    <h3>Customer Details</h3>
                    <p><strong>Name:</strong> <%= customerDetails.CustomerName %></p>
                    <p><strong>Address:</strong> <%= customerDetails.BillingAddress %>,<%= customerDetails.BillingDistrict %>,
                        <%= customerDetails.BillingState %>, <%= customerDetails.BillingPincode %>
                    </p>
                    <p><strong>Contact No:</strong> <%= customerDetails.MobileNo %></p>
                    <p><strong>GstIn No:</strong> <%= customerDetails.GstNo %></p>
                    <p><strong>Dl No:</strong> <%= customerDetails.DlNo %></p>
                </div>
                <div class="col-3">
                    <button class="btn btn-success">
                        <i class="bi bi-file-earmark-excel"></i> <i class="bi bi-download"></i>
                    </button>
                </div>
            </div>
        <% } %>
        <table class="table table-striped table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Debit (₹)</th>
                    <th>Credit (₹)</th>
                    <th>Balance (₹)</th>
                </tr>
            </thead>
            <tbody>
                <% if (customerLedger && customerLedger.length > 0) { %>
                    <% customerLedger.forEach((entry) => { %>
                        <tr>
                            <td><%= new Date(entry.Date).toLocaleString() %></td>
                            <td><%= entry.Description %></td>
                            <td><%= entry.Debit ? entry.Debit : '0' %></td>
                            <td><%= entry.Credit ? entry.Credit : '-' %></td>
                            <td><%= entry.Balance %></td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="text-center">No transactions found for this customer</td>
                    </tr>
                <% } %>
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="2">Total</th>
                    <th><%= totalDebit.toFixed(2) %></th>
                    <th><%= totalCredit.toFixed(2) %></th>
                    <th></th>
                </tr>
                <tr>
                    <th colspan="4">Closing Balance</th>
                    <th><%= closingBalance %></th>
                </tr>
            </tfoot>
        </table>
    </div>
</section>
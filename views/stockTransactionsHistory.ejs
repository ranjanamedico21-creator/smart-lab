<section class="py-3">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="bg-body rounded-4 border px-4 py-3 shadow-sm">
      <ol class="breadcrumb mb-0 small">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none fw-semibold">
            <i class="bi bi-house-door me-1"></i>Dashboard
          </a>
        </li>
        <li class="breadcrumb-item active fw-semibold" aria-current="page">
          Stock Transactions of <%=productDeatails.ProductName %> of Batch <%=productDeatails.BatchNumber %>
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Summary Section -->
<section class="pb-3">
  <div class="container-fluid">
    <div class="row g-3">

      <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body text-center">
            <small class="text-muted text-uppercase">Current Stock</small>
            <h4 class="fw-bold <%= currentStock >= 0 ? 'text-success' : 'text-danger' %> mb-0">
              <%= currentStock || 0 %>
            </h4>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body text-center">
            <small class="text-muted text-uppercase">Total Added</small>
            <h4 class="fw-bold text-success mb-0">
              <%= totalAdded || 0 %>
            </h4>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body text-center">
            <small class="text-muted text-uppercase">Total Reduced</small>
            <h4 class="fw-bold text-danger mb-0">
              <%= totalReduced || 0 %>
            </h4>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-body text-center">
            <small class="text-muted text-uppercase">Net Change</small>
            <h4 class="fw-bold <%= netStock >= 0 ? 'text-success' : 'text-danger' %> mb-0">
              <%= netStock || 0 %>
            </h4>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- Filters -->
<section class="pb-3">
  <div class="container-fluid">
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body">

        <form method="GET" class="row g-3 align-items-end">

          <div class="col-md-3">
            <label class="form-label small text-muted">Search</label>
            <input type="text" name="search" class="form-control"
              placeholder="Search remarks..." value="<%= search || '' %>">
          </div>

          <div class="col-md-2">
            <label class="form-label small text-muted">Type</label>
            <select name="type" class="form-control">
              <option value="">All</option>
              <option value="ADD" <%= type === 'ADD' ? 'selected' : '' %>>Add</option>
              <option value="REDUCE" <%= type === 'REDUCE' ? 'selected' : '' %>>Reduce</option>
              <option value="ADJUST" <%= type === 'ADJUST' ? 'selected' : '' %>>Adjust</option>
            </select>
          </div>

          <div class="col-md-2">
            <label class="form-label small text-muted">From</label>
            <input type="text" name="fromDate" value="<%= fromDate || '' %>" id="FromDate" autocomplete="off" class="form-control">
          </div>

          <div class="col-md-2">
            <label class="form-label small text-muted">To</label>
            <input type="text" name="toDate" value="<%= toDate || '' %>"id="ToDate" autocomplete="off" class="form-control">
          </div>

          <div class="col-md-2">
            <button class="btn btn-primary w-100">
              <i class="bi bi-search me-1"></i> Apply
            </button>
          </div>

        </form>

      </div>
    </div>
  </div>
</section>


<!-- Transaction Table -->
<section class="pb-5">
  <div class="container-fluid">

    <div class="card border-0 shadow-sm rounded-4">

      <div class="table-responsive" style="max-height: 500px;">
        <table class="table table-hover align-middle mb-0">

          <thead class="table-light sticky-top">
            <tr class="text-uppercase small text-muted">
              <th class="ps-4">#</th>
              <th class="text-center">Type</th>
              <th class="text-center">Quantity</th>
              <th class="text-center" style="min-width: 160px;">Date</th>
              <th>Remarks</th>
              <th class="text-center">Opening</th>
              <th class="text-center">Running Balance</th>

            </tr>
          </thead>

          <tbody>
            <% if (transactions && transactions.length > 0) { %>
              <% transactions.forEach((t, i) => { %>
                <tr>

                  <td class="ps-4 text-muted"><%= i + 1 %></td>

                  <td class="text-center">
                    <span class="badge rounded-pill px-3 py-2 fw-semibold
                    <%= 
                    t.TransactionType === 'ADD' ? 'bg-success-subtle text-success' :
                    t.TransactionType === 'REDUCE' ? 'bg-danger-subtle text-danger' :
                    t.TransactionType.includes('EXPIRED') ? 'bg-danger-subtle text-danger' :
                    t.TransactionType.includes('RETURN') ? 'bg-info-subtle text-info' :
                    'bg-warning-subtle text-warning'
                    %>">
                      <%= t.TransactionType %>
                    </span>
                  </td>

                  <td class="fw-semibold text-center">
                    <%= t.Quantity %>
                  </td>

                  <td class="text-center text-muted small" style="min-width:160px;">
                    <%= new Date(t.Timestamp).toLocaleDateString('en-GB', {
                      day: '2-digit',
                      month: 'short',
                      year: 'numeric'
                    }) %>
                  </td>

                  <td class="text-muted small">
                    <%= t.Remarks || '—' %>
                  </td>
                  <td class="text-center fw-semibold">
                    <%= i === 0 ? openingBalance : transactions[i-1].runningBalance %>
                  </td>
                  
                  <td class="text-center fw-bold">
                    <%= t.runningBalance %>
                  </td>
                  

                </tr>
              <% }) %>
            <% } else { %>

              <tr>
                <td colspan="5" class="text-center py-5 text-muted">
                  No transactions found
                </td>
              </tr>

            <% } %>
          </tbody>

        </table>
      </div>


      <!-- Pagination -->
      <div class="card-footer bg-body border-top py-3">
        <nav>
          <ul class="pagination justify-content-center mb-0">

            <% if (currentPage > 1) { %>
              <li class="page-item">
                <a class="page-link" href="?page=<%= currentPage - 1 %>">Previous</a>
              </li>
            <% } %>

            <% for (let p = 1; p <= totalPages; p++) { %>
              <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                <a class="page-link" href="?page=<%= p %>&search=<%= search || '' %>&type=<%= type || '' %>&fromDate=<%= fromDate || '' %>&toDate=<%= toDate || '' %>"
                  ><%= p %></a>
              </li>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <li class="page-item">
                <a class="page-link" href="?page=<%= currentPage + 1 %>">Next</a>
              </li>
            <% } %>

          </ul>
        </nav>
      </div>

    </div>

  </div>
</section>

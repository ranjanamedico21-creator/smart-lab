<section>
  <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item active text-dark" aria-current="page">user Activity </li>
    </ol>
  </nav>
</section>
<section>
  <div class="container-fluid rounded border bg-white shadow-sm mt-3">
    <div class="row mt-3 text-center">
      <div class="col">
        <h4>Patient List</h4>
      </div>
    </div>
      <%- include ("./partials/messages"); %>
      <form action="/patient/searchEditedPatient" method="post">
  
        <!-- Row 1: Bill No and Patient Name -->
        <div class="row g-3 mt-3">
          <div class="col-md-6">
            <input type="number" class="form-control" id="billNo" name="BillNo" placeholder="Bill No" value="<%= typeof BillNo!= 'undefined' ? BillNo : '' %>">
          </div>
          <div class="col-md-6">
            <input type="text" class="form-control" id="name" name="Name" placeholder="Enter Patient Name" value="<%= typeof Name!= 'undefined' ? Name : '' %>">
          </div>
        </div>
  
        <!-- Row 2: From Date and To Date -->
        <div class="row g-3 mt-3">
          <div class="col-md-6">
            <input type="text" id="FromDate" class="form-control" name="FromDate" placeholder="From date" value="<%= typeof FromDate!= 'undefined' ? FromDate : '' %>" autocomplete="off">
          </div>
          <div class="col-md-6">
            <input type="text" class="form-control" id="ToDate" name="ToDate" placeholder="To Date" value="<%= typeof ToDate!= 'undefined' ? ToDate : '' %>" autocomplete="off">
          </div>
        </div>
  
        <!-- Row 3: Doctor and Status -->
        <div class="row g-3 mt-3">
          <div class="col-md-6">
            <select name="Doctor" class="form-control" id="doctor" data-live-search="true" aria-label="select doctor with live search">
              <option value="" selected>Select a Doctor</option>
              <% i=1;doctorDetails.forEach(function(doctor){ %>
              <option value="<%=doctor.Id%>" <% if(typeof doctorId != 'undefined' && doctor.Id == doctorId){%>Selected <%}%> ><%=doctor.FirstName%> <%=doctor.LastName%></option>
              <%})%>
            </select>
          </div>
          <div class="col-md-6">
            <select name="Status" id="status" aria-label="status" class="form-control">
              <option value="" selected>Status</option>
              <option <% if(typeof Status != 'undefined' && Status == '1'){%>Selected <%}%> value="1">Active</option>
              <option <% if(typeof Status != 'undefined' && Status == '2'){%>Selected <%}%> value="2">Cancelled</option>
            </select>
          </div>
        </div>
  
        <!-- Row 4: Buttons -->
        <div class="row g-3 mt-3 mb-3">
          <div class="col-md-6">
            <button class="btn btn-primary w-100" type="submit">Search</button>
          </div>
        </div>
      </form>
    </div>
  <hr>

<!-- Patient List Table -->
    <table class="table table-striped">
      <thead>
        <tr>
          <th>#</th>
          <th class="font-monospace">Patient Detail</th>
          <th class="font-monospace">Referred By</th>
          <th class="font-monospace">Gross Amount</th>
          <th class="font-monospace">Date</th>
          <th class="font-monospace">Status</th>
          <th class="font-monospace">Action</th>
        </tr>
      </thead>
      <tbody class="pagination-loop">
        <% i=1;patientDetailsHistory.forEach(function(patient){ %>
        <tr <% if(patient.DuesAmount>0){%>class="table-danger" <%}%>>
          <th scope="row"><%=i%>.</th>
          <td class="text-capitalize">
            <p>
              <a href="/patient/getPatientEditedHistory?patientId=<%=patient.Id%>" class="link-body-emphasis text-decoration-none"><%=patient.title%> <%=patient.Name%></a> 
              <span><%=patient.Age%> <%=patient.YMD%> | <%=patient.Gender %></span>
            </p>
            <p><%=patient.PhoneNumber%></p>
          </td>
          <td>
            <p class="text-capitalize">Dr. <%= patient.FirstName%> <%= patient.LastName%></p>
            <p class="text-capitalize"> <%= patient.Degree%></p>
          </td>
          <td><%= patient.GrossAmount%></td>
          <td><%= patient.RegisteredOn%></td>
          <td <% if(patient.Status==2){%>class="text-danger"<%}%>><% if(patient.Status==1){%>Active<%}else{%>Cancelled <%}%></td>
          <td>
            
          </td>
        </tr>
        <% i++; })%>
      </tbody>
    </table>
</section>
<section>
  <!-- Pagination for navigation -->
  <nav aria-label="Page navigation">
    <ul class="pagination pagination-sm justify-content-center mt-3">
      <li class="page-item disabled">
        <a class="page-link">Previous</a>
      </li>
      <ul class="pagination pagination-sm pager" id="pagination_Number"></ul>
      <li class="page-item">
        <a class="page-link" href="#">Next</a>
      </li>
    </ul>
  </nav>
</section>





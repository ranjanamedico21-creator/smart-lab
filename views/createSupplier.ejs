<!-- Breadcrumb Section -->
<section class="py-4">
    <div class="container-fluid">
      <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded-3 shadow-sm border">
        <ol class="breadcrumb mb-0 fw-medium">
          <li class="breadcrumb-item">
            <a href="/user/home" class="text-decoration-none text-primary">Home</a>
          </li>
          <li class="breadcrumb-item active text-dark" aria-current="page">Create Supplier</li>
        </ol>
      </nav>
    </div>
  </section>
  
  <!-- Supplier Registration Section -->
  <section class="pb-5">
    <div class="container-fluid">
      <div class="card shadow border-0 rounded-4 bg-white overflow-hidden">
        <div class="card-header bg-gradient bg-primary text-white text-center py-3">
          <h4 class="mb-0 fw-bold">Supplier Registration</h4>
        </div>
        <div class="card-body p-4">
          <form action="/billing/createSupplier" class="needs-validation" novalidate method="post">
            <div class="row g-3">
              <!-- Supplier Name -->
              <div class="col-md-6">
                <label for="supplierName" class="form-label fw-semibold">Supplier Name</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof Name != 'undefined' ? Name : '' %>" 
                  name="Name" 
                  id="supplierName" 
                  placeholder="Supplier Name" 
                  required>
                <div class="invalid-feedback">Supplier Name is required.</div>
              </div>
              <!-- GSTIN -->
              <div class="col-md-6">
                <label for="GstIn" class="form-label fw-semibold">GSTIN</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof GstIn != 'undefined' ? GstIn : '' %>" 
                  name="GstIn" 
                  id="GstIn" 
                  placeholder="GSTIN" 
                  required>
                <div class="invalid-feedback">GSTIN is required.</div>
              </div>
            </div>
  
            <div class="row g-3 mt-3">
              <!-- Address -->
              <div class="col-md-3">
                <label for="address" class="form-label fw-semibold">Address</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof Address != 'undefined' ? Address : '' %>" 
                  name="Address" 
                  id="address" 
                  placeholder="Address" 
                  required>
                <div class="invalid-feedback">Address is required.</div>
              </div>
              <!-- City -->
              <div class="col-md-3">
                <label for="city" class="form-label fw-semibold">City</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof City != 'undefined' ? City : '' %>" 
                  name="City" 
                  id="city" 
                  placeholder="City" 
                  required>
                <div class="invalid-feedback">City is required.</div>
              </div>
              <!-- State -->
              <div class="col-md-3">
                <label for="state" class="form-label fw-semibold">State</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof State != 'undefined' ? State : '' %>" 
                  name="State" 
                  id="state" 
                  placeholder="State" 
                  required>
                <div class="invalid-feedback">State is required.</div>
              </div>
              <!-- Pincode -->
              <div class="col-md-3">
                <label for="pincode" class="form-label fw-semibold">Pincode</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof Pincode != 'undefined' ? Pincode : '' %>" 
                  name="Pincode" 
                  id="pincode" 
                  placeholder="Pincode" 
                  required>
                <div class="invalid-feedback">Pincode is required.</div>
              </div>
            </div>
  
            <div class="row g-3 mt-3">
              <!-- Mobile Number -->
              <div class="col-md-5">
                <label for="MobileNumber" class="form-label fw-semibold">Mobile Number</label>
                <input 
                  type="tel" 
                  class="form-control" 
                  value="<%= typeof MobileNumber != 'undefined' ? MobileNumber : '' %>" 
                  name="MobileNumber" 
                  id="MobileNumber" 
                  placeholder="Mobile Number" 
                  required>
                <div class="invalid-feedback">Mobile Number is required.</div>
              </div>
              <!-- Landline (STD Code + Number) -->
              <div class="col-md-3">
                <label for="stdCode" class="form-label fw-semibold">STD Code</label>
                <input 
                  type="text" 
                  class="form-control" 
                  id="stdCode" 
                  name="StdCode" 
                  maxlength="6" 
                  pattern="\d{3,6}" 
                  placeholder="e.g., 011" 
                  required>
                <div class="invalid-feedback">Enter a valid STD Code (3-6 digits).</div>
              </div>
              <div class="col-md-4">
                <label for="landlineNo" class="form-label fw-semibold">Landline Number</label>
                <input 
                  type="text" 
                  class="form-control" 
                  id="landlineNo" 
                  name="LandlineNo" 
                  maxlength="10" 
                  pattern="\d{6,10}" 
                  placeholder="e.g., 12345678" 
                  required>
                <div class="invalid-feedback">Enter a valid Landline Number (6-10 digits).</div>
              </div>
            </div>
  
            <div class="row g-3 mt-3">
              <!-- DL Number -->
              <div class="col-md-6">
                <label for="dlNo" class="form-label fw-semibold">DL Number</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof DlNo != 'undefined' ? DlNo : '' %>" 
                  name="DlNo" 
                  id="dlNo" 
                  placeholder="DL Number">
              </div>
              <!-- CIN -->
              <div class="col-md-6">
                <label for="cin" class="form-label fw-semibold">CIN</label>
                <input 
                  type="text" 
                  class="form-control text-capitalize" 
                  value="<%= typeof CIN != 'undefined' ? CIN : '' %>" 
                  name="CIN" 
                  id="cin" 
                  placeholder="CIN">
              </div>
            </div>
  
            <div class="row mt-4 mb-3">
              <div class="col text-center">
                <button type="submit" class="btn btn-primary px-5 rounded-pill fw-medium">Submit</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
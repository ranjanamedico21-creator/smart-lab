<section>
    <form action="/patient/patientHistory" method="post">
        <!-- Row 1: Bill No and Patient Name -->
        <div class="row g-3 mt-3">
          <div class="col-md-6">
            <input type="number" class="form-control" id="billNo" name="BillNo" placeholder="Bill No" value="<%= typeof BillNo!= 'undefined' ? BillNo : '' %>">
          </div>
          <div class="col-md-6">
            <input type="text" class="form-control" id="name" name="Name" placeholder="Enter Patient Name" value="<%= typeof Name!= 'undefined' ? Name : '' %>">
          </div>
        </div>
    
        <!-- Row 2: From Date and To Date -->
        <div class="row g-3 mt-3">
          <div class="col-md-6">
            <input type="text" id="FromDate" class="form-control" name="FromDate" placeholder="From date" value="<%= typeof FromDate!= 'undefined' ? FromDate : '' %>" autocomplete="off">
          </div>
          <div class="col-md-6">
            <input type="text" class="form-control" id="ToDate" name="ToDate" placeholder="To Date" value="<%= typeof ToDate!= 'undefined' ? ToDate : '' %>" autocomplete="off">
          </div>
        </div>
    
        <!-- Row 3: Doctor and Status -->
        <div class="row g-3 mt-3">
          <div class="col-md-4">
            <select name="Doctor" class="form-control" id="doctor" data-live-search="true" aria-label="select doctor with live search">
              <option value="" selected>Select a Doctor</option>
              <% doctorDetails.forEach(function(doctor){ %>
              <option value="<%=doctor.Id%>" <% if(typeof doctorId != 'undefined' && doctor.Id == doctorId){%>Selected <%}%> ><%=doctor.FirstName%> <%=doctor.LastName%></option>
              <%})%>
            </select>
          </div>
          <div class="col-md-4">
            <select name="Status" id="status" aria-label="status" class="form-control">
              <option value="" selected>Status</option>
              <option <% if(typeof Status != 'undefined' && Status == '1'){%>Selected <%}%> value="1">Active</option>
              <option <% if(typeof Status != 'undefined' && Status == '2'){%>Selected <%}%> value="2">Cancelled</option>
            </select>
          </div>
          <div class="col-md-4">
            <select class="form-control rounded-3" id="mainCategory" name="MainCategory" aria-label="Category Name">
                <option selected disabled value="">Select Category</option>
                <% if (typeof categories != 'undefined') { %>
                    <% categories.forEach(function(category) { %>
                      <option value="<%= category.Id %>" <% if(typeof categoryId != 'undefined' && categoryId == category.Id){%>selected<%}%>  id="<%= category.Name %>">
                        <%= category.Name %>
                      </option>
                    <% }) %>
                <% } %>
            </select>
        </div>
        </div>
    
        <!-- Row 4: Buttons -->
        <div class="row g-3 mt-3 mb-3">
          <div class="col-md-6">
            <a class="btn btn-primary w-100" href="/patient/registerPatient" role="button">Register Patient</a>
          </div>
          <div class="col-md-6">
            <button class="btn btn-primary w-100" type="submit">Search</button>
          </div>
        </div>
    </form>
</section>
<section>
  <div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
      <thead class="table-primary">
        <tr>
          <th scope="col">#</th>
          <th scope="col">Patient Detail</th>
          <th scope="col">Referred By</th>
          <th scope="col">Gross Amount</th>
          <th scope="col">Date</th>
          <th scope="col">Status</th>
          <th scope="col">Registered By</th>
        </tr>
      </thead>
      <tbody class="pagination-loop">
        <% let i=1; patientDetails.forEach(function(patient){ %>
          <tr
            class="<% if (patient.DuesAmount > 0 && patient.Status == 1) { %>table-danger<% } %> <% if (patient.Status == 2) { %>text-decoration-line-through text-muted<% } %>"
          >
            <td><%=i%>.</td>
            <td class="text-capitalize">
              <p class="mb-1">
                <a data-bs-toggle="tooltip" data-bs-custom-class="custom-tooltip" data-bs-placement="top"
                  title="Click to get edit details." 
                   href="/patient/patientTimeLine/<%= patient.PatientId %>"
                  class="link-primary fw-semibold text-decoration-none">
                  <%= patient.Title %> <%= patient.Name %>
                </a>
              </p>
              <p class="text-muted mb-1">
                <% if(patient.Gender == 1) { %>
                  <i class="bi bi-gender-male text-info"></i> Male
                <% } else { %>
                  <i class="bi bi-gender-female text-danger"></i> Female
                <% } %>
                | <%= patient.Age %> <%= patient.YMD %>
              </p>
              <p class="mb-0">
                <i class="bi bi-phone text-success" style="font-size: 1rem;"></i>
                <span class="fw-medium">+91 <%= patient.PhoneNumber %></span>
              </p>
            </td>
            <td
              class="text-capitalize"
              data-bs-toggle="tooltip"
              data-bs-custom-class="custom-tooltip"
              data-bs-placement="top"
              title="<%=patient.DoctorDegree1%>,<%=patient.DoctorDegree2%>"
            >
              <strong class="text-teal">Dr. <%= patient.DoctorFirstName%> <%= patient.DoctorLastName %></strong>
              <br />
              <small class="text-muted">
                <i class="bi bi-clipboard-heart"></i> <%= patient.DoctorSpecialistIn %>
              </small>
            </td>
            <td class="fw-bold fs-7">₹ <%= patient.GrossAmount %></td>
            <td class="text-muted fs-7">
              <i class="bi bi-calendar-event"></i> <%= patient.RegisteredOn %>
            </td>
            <td
              class="<% if(patient.Status == 1) { %>text-success<% } else if(patient.Status == 2) { %>text-danger<% } %>"
            >
              <% if(patient.Status == 1) { %> Active <% } else { %> Cancelled <% } %>
            </td>
            <td class="text-capitalize">
              <%= patient.UserFirstName %>&nbsp;<%= patient.UserLastName %><br>
              (<%=patient.RegisteredOn %>&nbsp;,<%= patient.RegisteredTime %>)
            </td>
          </tr>
        <% i++; })%>
      </tbody>
    </table>
  </div>
</section>

<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-xl">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Create Test Category
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Form Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-folder-plus me-2"></i>Create Category
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include ("./partials/messages"); %>

        <form action="/category/createCategory" class="needs-validation" method="post" novalidate>
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label for="category" class="form-label fw-bold text-dark">Category Name</label>
              <input
                type="text"
                class="text-capitalize form-control"
                value="<%= typeof category != 'undefined' ? category : '' %>"
                aria-describedby="Enter Category name"
                name="category"
                id="category"
                placeholder="Enter Category Name"
                required
              />
              <div class="invalid-feedback">Please enter a category name.</div>
            </div>
            <div class="col-md-6">
              <label for="thanks" class="form-label fw-bold text-dark">Default Thanks</label>
              <input
                type="text"
                class="text-capitalize form-control"
                value="<%= typeof thanks != 'undefined' ? thanks : '' %>"
                aria-describedby="Enter default thanks"
                name="thanks"
                id="thanks"
                placeholder="Enter Default Thanks"
                required
              />
              <div class="invalid-feedback">Please enter a default thanks message.</div>
            </div>
          </div>

          <div class="text-center">
            <button type="submit" class="btn btn-primary px-5 py-2">
              Create Category
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Function Authorization Page
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Main Content Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-shield-check me-2"></i>Function Authorization
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include ("./partials/messages"); %>

        <!-- Already Authorized Functions -->
        <h5 class="mb-3 fw-bold">Already Authorized Functions</h5>
        <div class="table-responsive mb-4">
          <table class="table table-striped table-hover align-middle">
            <thead class="table-primary">
              <tr>
                <th>Authorized Functions</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% authorisedFunctions.forEach(function (authorisedFunctionList){ %> 
                <tr>
                  <td><%= authorisedFunctionList.FunctionName %></td>
                  <td>
                    <a href="/user/removeAuthorisation/<%= userId %>/<%= authorisedFunctionList.FunctionId %>" 
                       class="btn btn-danger btn-sm">
                      Remove Access
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Select New Functions -->
        <h5 class="mb-4 fw-bold">Select New Functions</h5>
        <form action="/user/authoriseAccess/<%=userId%>" method="POST" onsubmit="return validateForm()">
          <div class="accordion" id="unAuthorisedFunctions">
            <% let currentMainFunction = ''; %>
            <% unAuthorisedFunctionLists.forEach(function(row, index) { %>
              <% if (row.FunctionGroup !== currentMainFunction) { %>
                <% if (currentMainFunction !== '') { %>
                  </ul>
                  </div>
                  </div>
                  </div>
                <% } %>
                <div class="accordion-item">
                  <h2 class="accordion-header" id="heading<%= row.MainFunctionName %>">
                    <button class="accordion-button collapsed" 
                            type="button" 
                            data-bs-toggle="collapse" 
                            data-bs-target="#collapse<%= row.MainFunctionName %>" 
                            aria-expanded="false" 
                            aria-controls="collapse<%= row.MainFunctionName %>">
                      <b><%= row.FunctionGroup %></b>
                    </button>
                  </h2>
                  <div id="collapse<%= row.MainFunctionName %>" 
                       class="accordion-collapse collapse" 
                       aria-labelledby="heading<%= row.MainFunctionName %>" 
                       data-bs-parent="#unAuthorisedFunctions">
                    <div class="accordion-body">
                      <ul class="list-group list-group-flush">
              <% currentMainFunction = row.FunctionGroup; %>
              <% } %>
                <li class="list-group-item">
                  <div class="form-check">
                    <input class="form-check-input" 
                           type="checkbox" 
                           name="selectedFunctions[]" 
                           value="<%= row.FunctionId %>"
                           id="func<%= row.FunctionId %>">
                    <label class="form-check-label" for="func<%= row.FunctionId %>">
                      <%= row.FunctionName %>
                    </label>
                  </div>
                </li>
            <% }); %>
            <% if (currentMainFunction !== '') { %>
              </ul>
              </div>
              </div>
              </div>
            <% } %>
          </div>

          <!-- Submit Button -->
          <div class="text-center mt-4">
            <button type="submit" class="btn btn-primary px-4 py-2">
              Authorize Selected Functions
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  function validateForm() {
    const checkboxes = document.querySelectorAll('input[name="selectedFunctions[]"]');
    const isChecked = Array.from(checkboxes).some(checkbox => checkbox.checked);
    
    if (!isChecked) {
      // Assuming you have a Bootstrap alert partial included
      appendAlert("Please select at least one function before submitting.", "danger");
      return false;
    }
    return true;
  }
</script>
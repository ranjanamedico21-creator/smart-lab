<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Test List
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Search Form Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden mb-4">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-search me-2"></i>Search Tests
        </h4>
      </div>
      <div class="card-body p-4">
        <form action="/test/getTestListView" method="post">
          <div class="row g-3">
            <div class="col-12 col-md-3">
              <select class="form-control" name="category" aria-label="Category" id="category">
                <option value="0">Select Category</option>
                <% categories.forEach(function(category){ %>
                  <option <% if(typeof categoryId != "undefined" && category.Id == categoryId){%>Selected <%}%> id="<%= category.Id %>" value="<%= category.Id %>"><%= category.Name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-md-3">
              <input
                type="text"
                class="form-control"
                placeholder="Enter Test Name"
                aria-label="Enter Test Name"
                name="testName"
                value="<%= typeof testName!= 'undefined' ? testName : '' %>"
              />
            </div>
            <div class="col-12 col-md-2">
              <select class="form-control" name="status" aria-label="Status" id="status">
                <option <% if(typeof status != 'undefined' && status ==0){%>Selected <%}%> value="0">Select Status</option>
                <option <% if(typeof status != 'undefined' && status ==1){%>Selected <%}%> value="1">Active</option>
                <option <% if(typeof status != 'undefined' && status ==2){%>Selected <%}%> value="2">In Active</option>
              </select>
            </div>
            <div class="col-12 col-md-2 d-grid">
              <button type="submit" data-bs-title="Search Test" class="btn btn-primary" id="submit">
                Search Test
              </button>
            </div>
            <div class="col-12 col-md-2">
              <a href="/test/downloadTestInExcel" class="btn btn-success" target="_blank">
                  <i class="bi bi-file-earmark-excel"></i> Download Excel
              </a>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Test List Section -->
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-list-check me-2"></i>Test Details
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include ("./partials/messages"); %>
        <div class="table-responsive">
          <table class="table table-hover table-striped align-middle">
            <thead class="table-primary">
              <tr>
                <th scope="col">#</th>
                <th scope="col">Test Name</th>
                <th scope="col">Category</th>
                <th scope="col">Price</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody class="pagination-loop">
              <% let i = 1; testDetails.forEach(function(test){ %>
                <tr>
                  <td><%= i %>.</td>
                  <td><%= test.TestName %></td>
                  <td><%= test.Name %></td>
                  <td><%= test.Price %></td>
                  <td>
                    <a href="/test/editTest/<%= test.Id %>" class="text-primary">Edit</a>  
                    <% if(typeof test.Status != 'undefined' && test.Status == '1'){%> 
                      <a href="/test/makeTestInActive?testId=<%= test.Id %>" class="link-success">Active</a>
                    <%}%>
                    <% if(typeof test.Status != 'undefined' && test.Status == '2'){%> 
                      <a href="/test/makeTestActive?testId=<%= test.Id %>" class="link-danger">InActive</a>
                    <%}%>
                      <a href="/test/attachTest?testId=<%= test.Id %>" class="text-primary">Attach Test</a>
                    <% if(/pathology/i.test(test.Name)) {%>
                        <a href="/test/attachSubParameter/<%= test.Id %>/<%=test.CategoryId %>" class="text-primary">Attach SubParameter</a>
                    <%}%>
                  </td>
                </tr>
              <% i++ }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination Section -->
        <section class="pb-4">
          <div class="container-xl">
            <nav aria-label="Page navigation">
              <ul class="pagination pagination-sm justify-content-center gap-1" id="pagination_Number">
                <li class="page-item disabled">
                  <a class="page-link rounded-pill px-3" href="#">Previous</a>
                </li>
                <!-- Dynamic pagination numbers can be added here via JS -->
                <li class="page-item">
                  <a class="page-link rounded-pill px-3" href="#">1</a>
                </li>
                <li class="page-item">
                  <a class="page-link rounded-pill px-3" href="#">Next</a>
                </li>
              </ul>
            </nav>
          </div>
        </section>
      </div>
    </div>
  </div>
</section>
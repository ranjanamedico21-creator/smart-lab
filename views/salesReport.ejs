<!-- ===================== PAGE HEADER ===================== -->
<section class="mb-3">
  <div class="card shadow-sm border-0">
    <div class="card-body py-3">
      <div class="d-flex justify-content-between align-items-center flex-wrap">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item">
              <a href="/user/home" class="text-decoration-none">Home</a>
            </li>
            <li class="breadcrumb-item active">Sales Report</li>
          </ol>
        </nav>
        <h5 class="mb-0 fw-semibold text-primary">
          Customer-wise Sales Report
        </h5>
      </div>
    </div>
  </div>
</section>

<section class="mb-3">
  <div class="card shadow-sm border-0">
    <div class="card-body">

      <%- include("./partials/messages"); %>

      <form action="/billing/salesReportCustomerWise" method="post">
        <div class="row g-3 align-items-end">

          <!-- Customer -->
          <div class="col-md-4">
            <label class="form-label fw-semibold">Customer</label>
            <select name="Customer" class="form-control">
              <option value="">All Customers</option>
              <% customers.forEach(function(c){ %>
                <option value="<%= c.Id %>" 
                  <%= (typeof Customer !== 'undefined' && c.Id == Customer) ? 'selected' : '' %>>
                  <%= c.CustomerName %>
                </option>
              <% }) %>
            </select>
          </div>

          <!-- From Date -->
          <div class="col-md-3">
            <label class="form-label fw-semibold">From Date</label>
            <input type="text"
                   class="form-control"
                   id="FromDate"
                   name="FromDate"
                   value="<%= typeof FromDate !== 'undefined' ? FromDate : '' %>"
                   autocomplete="off">
          </div>

          <!-- To Date -->
          <div class="col-md-3">
            <label class="form-label fw-semibold">To Date</label>
            <input type="text"
                   class="form-control"
                   id="ToDate"
                   name="ToDate"
                   value="<%= typeof ToDate !== 'undefined' ? ToDate : '' %>"
                   autocomplete="off">
          </div>

          <!-- Buttons -->
          <div class="col-md-2 d-grid gap-2">
            <button class="btn btn-primary">
              🔍 Search
            </button>

            <a class="btn btn-success" href="/billing/salesReportForGst?Customer=<%= Customer %>&FromDate=<%= FromDate %>&ToDate=<%= ToDate %>">
                ⬇ Export Excel
            </a>

          </div>

        </div>
      </form>

    </div>
  </div>
</section>

<!-- ===================== SALES TABLE ===================== -->
<section>
  <% if (invoices && invoices.length > 0) { %>

    <% invoices.forEach(function(inv, index){ %>

      <div class="card shadow-sm border-0 mb-4">

        <!-- Invoice Header -->
        <div class="card-header bg-light d-flex justify-content-between flex-wrap">
          <div>
            <h6 class="fw-bold mb-1">
              Invoice: 
              <span class="badge bg-secondary">
                <%= inv.InvoiceId %>
              </span>
            </h6>
            <div class="small text-muted">
              Customer: <span class="fw-semibold text-dark"><%= inv.CustomerName %></span> |
              GST: <%= inv.GstNo %>
            </div>
          </div>

          <div class="text-end small">
            Date: 
            <%= new Date(inv.CreatedAt)
                .toLocaleDateString('en-GB')
                .replace(/\//g, '-') %>
          </div>
        </div>

        <!-- Products Table -->
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light small text-uppercase">
                <tr>
                  <th>#</th>
                  <th>Product</th>
                  <th class="text-end">Price</th>
                  <th class="text-end">Qty</th>
                  <th class="text-end">CGST %</th>
                  <th class="text-end">SGST %</th>
                  <th class="text-end">SGST Amount (₹)</th>
                  <th class="text-end">SGST Amount (₹)</th>
                  <th class="text-end">TV (₹) </th>
                  <th class="text-end">TVWT(₹)</th>
                </tr>
              </thead>
              <tbody>
                <% inv.Products.forEach(function(p, i){ %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td class="text-capitalize"><%= p.ProductName %></td>
                    <td class="text-end">₹ <%= p.SalePrice %></td>
                    <td class="text-end"><%= p.QuantitySold %></td>
                    <td class="text-end"><%= p.Sgst %></td>
                    <td class="text-end"><%= p.Cgst %></td>
                    <td class="text-end"> ₹ <%= p.SgstAmount %></td>
                    <td class="text-end">₹ <%= p.CgstAmount %></td>
                    <td class="text-end">₹ <%= p.TotalValue %></td>
                    <td class="text-end fw-semibold">
                      ₹ <%= p.TotalValueWithTax %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
        <!-- Invoice Footer -->
        <div class="card-footer bg-light text-end">
          <div class="fw-semibold">
            Subtotal: ₹ <%= inv.SubTotal.toFixed(2) %>
          </div>
          <div class="fw-semibold">
            Total Cgst: ₹ <%= Number(inv.TotalCgst || 0).toFixed(2) %>
          </div>
          <div class="fw-semibold">
            Total Sgst: ₹ <%= inv.TotalSgst %>
          </div>
          <div class="fw-bold text-success fs-6">
            Grand Total: ₹ <%= inv.GrandTotal.toFixed(2) %>
          </div>
        </div>

      </div>

    <% }) %>

  <% } else { %>
    <div class="card shadow-sm border-0">
      <div class="card-body text-center text-muted py-4">
        No records found
      </div>
    </div>
  <% } %>
</section>

<!-- ===================== PAGINATION ===================== -->
<section class="mt-3 mb-4">
  <div class="card border-0">
    <div class="card-body py-2">
      <nav>
        <ul class="pagination pagination-sm justify-content-center mb-0 gap-1" id="pagination_Number">
          <li class="page-item disabled">
            <a class="page-link rounded-pill px-3 prev_link">Previous</a>
          </li>

          <!-- Page numbers via JS -->

          <li class="page-item">
            <a class="page-link rounded-pill px-3 next_link">Next</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</section>
<!-- ===================== INVOICE GROUPED VIEW ===================== -->

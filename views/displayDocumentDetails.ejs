<!-- Breadcrumb -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none text-primary">Home</a></li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">Document List</li>
      </ol>
    </nav>
  </div>
</section>

<!-- Main Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold"><i class="bi bi-folder me-2"></i>Document List</h4>
      </div>

      <div class="card-body p-4">
        <%- include ("./partials/messages"); %>

        <!-- Search Form -->
        <form action="/report/searchDocument" class="needs-validation row g-3 mb-4" method="post" novalidate>
          <div class="col-md-4">
            <label for="documentCategory" class="form-label fw-bold">Document Category</label>
            <select name="documentCategory" class="form-control" id="documentCategory" aria-label="Select document category to filter document">
              <option value="" selected>Select a Document Category</option>
              <% i = 1; DocumentCategoryDetails.forEach(function(category) { %>
                <option value="<%= category.Id %>" <% if (typeof documentCategoryId != 'undefined' && category.Id == documentCategoryId) { %> selected <% } %>>
                  <%= category.Name %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-4">
            <label for="searchDocumentName" class="form-label fw-bold">Search Document Name</label>
            <input type="text" name="searchDocumentName" id="searchDocumentName" class="form-control"  value="<%= typeof documentName != 'undefined' ? documentName : '' %>"  placeholder="Enter document name" >
          </div>
          <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">Search</button>
          </div>
        </form>

        <!-- Document List Table -->
        <div class="table-responsive">
          <table class="table table-hover table-striped align-middle">
            <thead class="table-primary">
              <tr>
                <th scope="col" class="col-1">#</th>
                <th scope="col">Category Name</th>
                <th scope="col">Uploaded By</th>
                <th scope="col">Uploaded On</th>
                <th scope="col">Valid From</th>
                <th scope="col">Valid Upto</th>
                <th scope="col">Display</th>
                <th scope="col">Action</th>
              </tr>
            </thead>
            <tbody class="pagination-loop">
              <% i = 1; documentDetails.forEach(function(document) { %>
                <tr data-category="<%= document.CategoryId %>">
                  <th scope="row"><%= i %>.</th>
                  <td class="text-capitalize"><%= document.Name %></td>
                  <td><%= document.FirstName %> <%= document.LastName %></td>
                  <td><%= document.UploadedOn %></td>
                  <td><%= document.ValidFrom %></td>
                  <td><%= document.ValidUpto %></td>
                  <td>
                    <img class="zoom" style="cursor: pointer; width: 30px; height: 30px;"
                         src="/<%= document.DocumentName %>" 
                         alt="Document Preview"
                         onerror="this.src='/path/to/fallback.jpg'; console.log('Image not found:', this.src)"
                         data-bs-toggle="modal" data-bs-target="#imageModal">
                  </td>
                  <td>
                    <a href="#" class="text-decoration-none text-danger delete-document" 
                       data-document-id="<%= document.Id %>" 
                       data-bs-toggle="modal" 
                       data-bs-target="#deleteDocumentModal">
                      <i class="bi bi-trash"></i>
                    </a>
                  </td>
                </tr>
              <% i++; }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm justify-content-center gap-1 mt-4" id="pagination_Number">
            <li class="page-item disabled">
              <a class="page-link rounded-pill px-3" href="#">Previous</a>
            </li>
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">1</a>
            </li>
            <li class="page-item">
              <a class="page-link rounded-pill px-3" href="#">Next</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</section>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteDocumentModal" tabindex="-1" aria-labelledby="deleteDocumentModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteDocumentModalLabel">Confirm Deletion</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete this document?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form id="deleteDocumentForm" action="/report/deleteDocument" method="POST">
          <input type="hidden" name="deleteDocumentId" id="modalDocumentId">
          <button type="submit" class="btn btn-danger">Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Image Preview Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="imageModalLabel">Document Preview</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center">
        <img id="modalImage" src="" class="img-fluid" alt="Zoomed Image">
      </div>
    </div>
  </div>
</div>
<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
    <nav aria-label="breadcrumb" class="p-3 bg-light rounded-3 shadow-sm">
      <ol class="breadcrumb mb-0 d-flex align-items-center">
        <li class="breadcrumb-item">
          <a href="/user/home" class="text-decoration-none text W-primary">Home</a>
        </li>
        <li class="breadcrumb-item active fw-bold" aria-current="page">
          Dues Received List
        </li>
      </ol>
    </nav>
  </div>
</section>

<!-- Dues Received Section -->
<section class="pb-5">
  <div class="container-fluid">
    <div class="card border-0 shadow-lg rounded-3 overflow-hidden">
      <div class="card-header bg-primary text-white text-center py-3">
        <h4 class="mb-0 fw-bold">
          <i class="bi bi-cash me-2"></i>Dues Received
        </h4>
      </div>
      <div class="card-body p-4">
        <%- include("./partials/messages"); %>

        <!-- Search Form -->
        <form action="/patient/dailyDuesReceived" method="post" class="mb-4">
          <div class="row g-3 align-items-end">
            <div class="col-md-2 col-lg-1">
              <label for="FromDate" class="form-label fw-bold text-dark">From Date:</label>
            </div>
            <div class="col-md-4 col-lg-3">
              <input
                type="text"
                id="FromDate"
                class="form-control"
                name="FromDate"
                placeholder="From Date"
                value="<%= typeof FromDate != 'undefined' ? FromDate : '' %>"
                autocomplete="off"
              />
            </div>
            <div class="col-md-2 col-lg-1">
              <label for="ToDate" class="form-label fw-bold text-dark">To Date:</label>
            </div>
            <div class="col-md-4 col-lg-3">
              <input
                type="text"
                id="ToDate"
                class="form-control"
                name="ToDate"
                placeholder="To Date"
                value="<%= typeof ToDate != 'undefined' ? ToDate : '' %>"
                autocomplete="off"
              />
            </div>
            <div class="col-md-2 col-lg-4">
              <button type="submit" class="btn btn-primary w-100 py-2">Search</button>
            </div>
          </div>
        </form>

        <!-- Dues Table -->
        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">
            <thead class="table-primary">
              <tr>
                <th scope="col">#</th>
                <th scope="col">Patient Name</th>
                <th scope="col">Referred By</th>
                <th scope="col">Cash Amount</th>
                <th scope="col">Online Amount</th>
                <th scope="col">Received On</th>
                <th scope="col">Registered On</th>
                <th scope="col">Dues Received By</th>
              </tr>
            </thead>
            <tbody>
              <% 
                let totalCash = 0; 
                let totalOnline = 0; 
                let i = 1; 
                duesReceivedDetails.forEach(function(duesReceivedDetail) { 
                  totalCash += parseFloat(duesReceivedDetail.CashPayment || 0); 
                  totalOnline += parseFloat(duesReceivedDetail.OnlinePayment || 0); 
              %>
                <tr>
                  <td><%= i %>.</td>
                  <td>
                    <a
                      href="/patient/getPatientDetail?patientId=<%= duesReceivedDetail.PatientId %>"
                      class="link-primary text-decoration-none fw-medium"
                    >
                      <%= duesReceivedDetail.title %> <%= duesReceivedDetail.Name %>
                    </a>
                  </td>
                  <td>Dr. <%= duesReceivedDetail.FirstName %> <%= duesReceivedDetail.LastName %></td>
                  <td><%= duesReceivedDetail.CashPayment %></td>
                  <td><%= duesReceivedDetail.OnlinePayment %></td>
                  <td><%= duesReceivedDetail.ReceivedOn %></td>
                  <td><%= duesReceivedDetail.RegisteredOn %></td>
                  <td><%= duesReceivedDetail.FName %> <%= duesReceivedDetail.LName %></td>
                </tr>
              <% i++; }); %>
            </tbody>
            <tfoot>
              <tr>
                <td colspan="3" class="text-end fw-bold">Total:</td>
                <td class="fw-bold"><%= totalCash.toFixed(2) %></td>
                <td class="fw-bold"><%= totalOnline.toFixed(2) %></td>
                <td colspan="3"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
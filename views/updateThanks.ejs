// Toggle input field
function toggleInput(testId) {
  const checkbox = document.querySelector(`input[value="${testId}"]`);
  const inputField = document.getElementById(`newThanks_${testId}`);
  $('#selectedCategory').val($('#selectDoctorThanksCategorySearch').val());
  $('#searchedTestName').val($('#searchTest').val());
  inputField.disabled = !checkbox.checked;
  if (!checkbox.checked) {
    inputField.value = '';
  }
}
</script>

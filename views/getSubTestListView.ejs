<section>
  <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item active text-dark" aria-current="page">Sub Test View</li>
    </ol>
  </nav>
</section>
   <!--Hero section starts-->
<section>
  <div class="container-fluid rounded border bg-white shadow-sm mt-3">
    <div class="row mt-3 text-center">
      <div class="col">
        <h4>Test Details</h4>
      </div>
    </div>
    <%- include ("./partials/messages"); %>
    <table class="table table-striped">
      <thead>
        <tr>
          <th>#</th>
          <th>Sub Test Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Discount</th>
          <th>Thanks Amount</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody class="pagination-loop">
        <% i=1;SubTestLists.forEach(function(subTest){ %>
        <tr>
          <th scope="row"><%=i%>.</th>
          <td class="text-capitalize"><%=subTest.Name%></td>
          <td class="text-capitalize"><%=subTest.categoryName%></td>
          <td><%=subTest.Price%></td>
          <td><%=subTest.Discount%></td>
          <td><%=subTest.ThanksAmount%></td>
          <td><a href="/test/editSubTest?SubTestId=<%=subTest.SubTestId%>">Edit</a></td>   
        </tr>
        <% i++})%>
      </tbody>
    </table>
  </div>
</section>
<section>
  <!-- Pagination for navigation -->
  <nav aria-label="Page navigation">
    <ul class="pagination pagination-sm justify-content-center mt-3">
      <li class="page-item disabled">
        <a class="page-link">Previous</a>
      </li>
      <ul class="pagination pagination-sm pager" id="pagination_Number"></ul>
      <li class="page-item">
        <a class="page-link" href="#">Next</a>
      </li>
    </ul>
  </nav>
</section>


  
       
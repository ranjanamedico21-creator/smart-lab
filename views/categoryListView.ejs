<!-- Breadcrumb Section -->
<section class="py-4">
  <div class="container-fluid">
      <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded-3 shadow-sm border">
          <ol class="breadcrumb mb-0 fw-medium">
              <li class="breadcrumb-item">
                  <a href="/user/home" class="text-decoration-none text-primary">Home</a>
              </li>
              <li class="breadcrumb-item active text-dark" aria-current="page">Category List View</li>
          </ol>
      </nav>
  </div>
</section>

<!-- Category Details Section -->
<section class="pb-5">
  <div class="container-fluid">
      <div class="card shadow border-0 rounded-4 bg-white overflow-hidden">
          <div class="card-header bg-gradient bg-primary text-white text-center py-3">
              <h4 class="mb-0 fw-bold">Category Details</h4>
          </div>
          <div class="card-body p-0">
              <!-- Server-side rendered messages (optional) -->
              <%- include ("./partials/messages"); %>

              <div class="table-responsive">
                  <table class="table table-hover table-striped align-middle mb-0 table-borderless">
                      <thead class="bg-teal-800 bg-gradient">
                          <tr>
                              <th scope="col" class="ps-4 py-3 fw-semibold rounded-start text-center text-nowrap">#</th>
                              <th scope="col" class="py-3 fw-semibold text-center text-nowrap">Category Name</th>
                              <th scope="col" class="py-3 fw-semibold text-center text-nowrap">Created By</th>
                              <th scope="col" class="py-3 fw-semibold text-center text-nowrap">Created On</th>
                              <th scope="col" class="py-3 fw-semibold rounded-end text-center text-nowrap">Action</th>
                          </tr>
                      </thead>
                      <tbody class="bg-white">
                          <% if (categoryDetails && categoryDetails.length > 0) { %>
                              <% let i = 1; categoryDetails.forEach(function(category) { %>
                                  <tr class="transition-all hover-bg-light">
                                      <td class="ps-4 py-3 fw-medium text-muted text-center"><%= i %>.</td>
                                      <td class="py-3 fw-medium text-center text-truncate" style="max-width: 200px;"><%= category.Name %></td>
                                      <td class="py-3 fw-medium text-center text-truncate" style="max-width: 200px;"><%= category.FirstName %> <%= category.LastName %></td>
                                      <td class="py-3 fw-medium text-center text-nowrap"><%= category.CreatedOn %></td>
                                      <td class="py-3 text-center">
                                          <a href="/category/editCategory/<%=category.Id%>" 
                                             class="btn btn-sm btn-primary rounded-pill px-3 fw-medium text-decoration-none">
                                              Edit
                                          </a>
                                      </td>
                                  </tr>
                              <% i++; }) %>
                          <% } else { %>
                              <tr>
                                  <td colspan="5" class="text-center py-4 text-muted fw-medium">
                                      <i class="bi bi-info-circle me-2"></i>No categories available
                                  </td>
                              </tr>
                          <% } %>
                      </tbody>
                  </table>
              </div>
          </div>
      </div>
  </div>
</section>

<!-- Pagination Section -->
<section class="pb-4">
  <div class="container-fluid">
      <nav aria-label="Page navigation">
          <ul class="pagination pagination-sm justify-content-center gap-1 flex-wrap">
              <li class="page-item disabled">
                  <a class="page-link rounded-pill px-3" href="#">Previous</a>
              </li>
              <li class="page-item">
                  <a class="page-link rounded-pill px-3" href="#">1</a>
              </li>
              <li class="page-item">
                  <a class="page-link rounded-pill px-3" href="#">Next</a>
              </li>
          </ul>
      </nav>
  </div>
</section>
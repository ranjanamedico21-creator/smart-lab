<section>
  <nav aria-label="breadcrumb" class="breadcrumb-nav p-3 bg-light rounded shadow-sm">
    <ol class="breadcrumb mb-0">
      <li class="breadcrumb-item"><a href="/user/home" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item active text-dark" aria-current="page">Register Patient </li>
    </ol>
  </nav>
</section>
<section>
  <div class="container-fluid rounded border bg-white shadow-sm mt-3">
      <div class="row mt-3 text-center">
        <div class="col text-center">
          <h4>Register Patient</h4>
        </div>
      </div>
      <%- include ("./partials/messages"); %>
      <form action="/patient/registerPatient" method="post" class="needs-validation" novalidate>
        <div class="row">
          <div class="col-7">
            <!--Divide into two part . first part is this in which patient details are taken and theese are on left side -->
            <div class="row">
                <div class="col-lg-6">
                    <!-- Date Field -->
                    <div class="input-group">
                      <input type="text" class="form-control" id="date" placeholder="Date" readonly>
                      <span class="input-group-text">
                        <i class="bi bi-calendar2-date-fill"></i>
                      </span>
                    </div>
                </div>
            </div>
  
            <!-- Title and Gender -->
            <div class="row g-3 mt-3">
                <div class="col-md-4">
                  <select class="form-control" id="title" name="title" required>
                    <option value="">Title</option>
                    <option value="Dr."  <% if(typeof patientDetails.title != 'undefined' && patientDetails.title =='Dr.'){%>Selected <%}%>>Dr.</option>
                    <option value="Mr."  <% if(typeof patientDetails.title != 'undefined' && patientDetails.title =='Mr.'){%>Selected <%}%>>Mr.</option>
                    <option value="Mrs."  <% if(typeof patientDetails.title != 'undefined' && patientDetails.title =='Mrs.'){%>Selected <%}%>>Mrs.</option>
                    <option value="Miss"  <% if(typeof patientDetails.title != 'undefined' && patientDetails.title =='Miss'){%>Selected <%}%>>Miss</option>
                    <option value="Master"  <% if(typeof patientDetails.title != 'undefined' && patientDetails.title =='Master'){%>Selected <%}%>>Master</option>
                    <option value="Baby Of"  <% if(typeof patientDetails.title != 'undefined' && patientDetails.title =='Baby Of'){%>Selected <%}%>>Baby Of</option>           
                  </select>
                </div>
                <div class="col-md-4">
                  <select class="form-control" id="gender" name="gender" required>
                    <option value="">Select Gender</option>
                    <option value="1"  <% if(typeof patientDetails.gender != 'undefined' && patientDetails.gender =='1'){%>Selected <%}%>> Male</option>
                    <option value="2"  <% if(typeof patientDetails.gender != 'undefined' && patientDetails.gender =='2'){%>Selected <%}%>>Female</option>
                  </select>
                </div>
                <div class="col-md-4">
                  <div class="form-check form-switch">
                    <input class="form-check-input border-danger" type="checkbox" id="isEmergency" name="isEmergency" value="1"
                      <%= typeof patientDetails.isEmergency !== 'undefined' && patientDetails.isEmergency == 1 ? 'checked' : '' %>>
                    <label class="form-check-label fw-semibold" for="isEmergency">
                      IS EMERGENCY?
                    </label>
                  </div>
                </div>
            </div>
  
            <!-- Name and Age -->
            <div class="row g-3 mt-3">
                <div class="col-md-6">
                  <input type="text" placeholder="Patient Name" class="form-control" id="patientName" name="patientName" value="<%= typeof patientDetails.patientName != 'undefined' ? patientDetails.patientName : '' %>" required>
                </div>
                <div class="col-md-3">
                  <input type="number" placeholder="Age"  class="form-control" id="age" name="age" value="<%= typeof patientDetails.age != 'undefined' ? patientDetails.age : '' %>" required>
                </div>
                <div class="col-md-3">
                  <select class="form-control" id="ymd" name="ymd" required>
                    <option value="">Select</option>
                    <option  value="Years" <% if(typeof patientDetails.ymd != 'undefined' && patientDetails.ymd =='Years'){%>Selected <%}%>>Year</option>
                    <option  value="Months"  <% if(typeof patientDetails.ymd != 'undefined' && patientDetails.ymd =='Months'){%>Selected <%}%> >Month</option>
                    <option  value="Days"  <% if(typeof patientDetails.ymd != 'undefined' && patientDetails.ymd =='Days'){%>Selected <%}%> >Days</option>
                  </select>  
                </div>
            </div>
  
            <!-- Clinic and Doctor -->
            <div class="row g-3 mt-3">
                <div class="col-md-6">
                  <select name="clinic" class="form-control" id="clinic" data-live-search="true" required>
                    <option value="">Select a clinic</option>
                      <% clinics.forEach(function(clinic){ %>
                    <option class="text-capitalize" <% if(typeof clinicId != 'undefined' && clinic.Id ==clinicId){%>Selected <%}%> value="<%=clinic.Id%>" class="clinicListAction" data-clinic="<%=clinic.Name %>" data-address="<%=clinic.Address %>"><%=clinic.Name %>[<%=clinic.Address %>]</option>
                      <%})%>
                  </select>
                </div>
                <div class="col-md-6">
                  <select name="doctor" class="form-control" id="doctor" required>
                    <option value="">Select a Doctor</option>
                    <% doctors.forEach(function(doctor){ %>
                    <option data-flat-discount="<%=doctor.FlatDiscount%>" data-authorized-For-Blood="<%=doctor.AuthorizedForBloodTest %>" <% if(typeof doctor != 'undefined' && doctor.Id == doctorId){%>Selected <%}%> value="<%=doctor.Id%>"><%=doctor.FirstName%> <%=doctor.LastName%></option>    <%})%>
                  </select>
                  </select>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col">
                    <span>Address:</span>
                    <span id="address" class="text-capitalize"></span>
                </div>
                <div class="col">
                    <span>Qualification:</span>
                    <span id="qualification" class="text-capitalize"></span>
                </div>
            </div>
            <!-- Address and Phone -->
            <div class="row g-3 mt-3">
                <div class="col-md-6">
                  <input type="text" placeholder="Phone Number"class="form-control" id="phoneNumber" name="phoneNumber" value="<%= typeof patientDetails.phoneNumber != 'undefined' ? patientDetails.phoneNumber : '' %>" required minlength="10" maxlength="10">
                </div>
                <div class="col-md-6">
                  <input type="text" placeholder="Patient Address" class="form-control" id="patientAddress" name="patientAddress" value="<%= typeof patientDetails.patientAddress != 'undefined' ? patientDetails.patientAddress : '' %>">
                </div>
            </div>
          </div>
          <!-- divides into two part this is second part. clinic image on the right side of half of the page-->
          <div class="col-5">
            <div class="row g-3 mt-3">
              <div class="col">
                <img src="" class="img-fluid" alt="clinic prescription" id="clinicPrescription">
              </div>
            </div>
          </div>
        </div>
            
            <div class="row  g-3 mt-3">
              <div class="col">
                  <div id="liveErrorAlertPlaceholder"></div>
              </div>
            </div>
  
        <!-- Test Section -->
        <div class="row g-3 mt-3">
            <div class="col-md-3">
              <select class="form-control" id="category" name="category" required>
                <option id="0">Select Category</option>
                  <% categories.forEach(function(category){ %>
                <option id="category<%= category.Id %>" value="<%= category.Id %>" data-category-id="<%=category.Id%>""><%= category.Name %></option>
                      <% })%>
              </select>
            </div>
            <div class="col-md-3">
              <select class="form-control" id="test" name="test" data-live-search="true" required>
                <option id="0" data-category-id="0" >Select Test</option>
                    <% testDetails.forEach(function(test){ %>
                <option id="<%= test.Id %>" value="<%= test.Id %>" data-category-id="<%=test.CategoryId %>" data-price="<%=test.Price%>"><%=test.TestName %></option>
                              <% })%>
              </select>
            </div>
            <div class="col-md-2">
              <input type="number" class="form-control" id="price" name="price" value="0" placeholder="Test Price" readonly required>
            </div>
            <div class="col-md-2">
              <input type="number" class="form-control" id="discount" placeholder="Discount" name="discount" value="0">
            </div>
            <div class="col-md-2">
              <input class="btn btn-primary" type="button" value="Add Test" id="addTest">
            </div>
        </div>
  
        <div class="row d-flex justify-content-between align-items-center mt-3">
          <div class="col">
            <table class="table table-striped" id="displayTest">
              <thead>
                <tr>
                  <th>Test Name</th>
                  <th>Price</th>
                  <th>Discount</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <!-- Dynamically add rows here -->
              </tbody>
            </table>
          </div>
        </div>
        <h5 class="fw-semibold text-primary mt-4 mb-1">
          <i class="bi bi-cash-coin me-2"></i> Billing Summary
        </h5>
        <div class="row g-3 mb-3">
          <div class="col-md-4">
            <div class="input-group">
              <input type="text" class="form-control" placeholder="Discount" name="finalDiscount" id="finalDiscount" readonly="" value="">
              <span class="input-group-text">Total Discount (₹)</span>
            </div>
          </div>
          <div class="col-md-4">
            <div class="input-group">
              <input type="text" class="form-control text-capitalize" placeholder="Discount Approved By" id="discountApprovedBy" name="discountApprovedBy" value="">
              <span class="input-group-text">Approved By</span>
            </div>
          </div>
          <div class="col-md-4">
            <div class="input-group">
              <input type="number" class="form-control" placeholder="Gross Amount" id="grossAmount" name="grossAmount" readonly="" required="" value="">
              <span class="input-group-text">Gross Amount (₹)</span>
            </div>
          </div>
        </div>
        <h5 class="fw-semibold text-primary mt-4 mb-3">
          <i class="bi bi-wallet2 me-2"></i> Payment Details
        </h5>
        <!-- Payment Section -->
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <div class="input-group">
              <input type="number" class="form-control" id="cashPayment" name="cashPayment" required="" value="0">
              <span class="input-group-text">Cash (₹)</span>
            </div>
          </div>
          <div class="col-md-6">
            <div class="input-group">
              <input type="number" class="form-control" id="onlinePayment" name="onlinePayment" required="" value="0">
              <span class="input-group-text">Online (₹)</span>
            </div>
          </div>
        </div>
  
        <div class="d-flex justify-content-start gap-2 mt-3">
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle me-1"></i> Register
          </button>
          <a href="/patient/getPatientListView" class="btn btn-outline-secondary">
            <i class="bi bi-list-ul me-1"></i> Patient List
          </a>
        </div>
        <input type="hidden" name="selectedTestDetails" id="selectedTestDetails" value="[]">
        <input type="hidden" name="testLength" id="testLength" value="0">
        <input type="hidden" name="subTestLength" id="subTestLength" value="0">
        <input type="hidden" name="patientTestDetails" id="patientTestDetails" value="<%= typeof patientTestDetails!= 'undefined' ? patientTestDetails : '' %>">
        <input type="hidden" name="selectedSubTestDetails" id="selectedSubTestDetails" value="[]">
        <input type="hidden" name="patientSubTestDetails" id="patientSubTestDetails" value="<%= typeof patientSubTestDetails!= 'undefined' ? patientSubTestDetails : '' %>">
        <ul class="invisible">
          <% subTestDetails.forEach(function(subTest){ %>
              <li class="mainTest<%=subTest.mainTestId%>" data-sub-test-price="<%=subTest.Price%>" data-sub-test-name="<%=subTest.Name%>"data-sub-test-discount="<%=subTest.Discount%>" data-sub-test-id="<%=subTest.subTestId%>"></li>
              <%})%>
        </ul>
                
      </form>
  </div>
</section>